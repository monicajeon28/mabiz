// ============================================================================
// MODEL 1: Funnel (Base Model) — ADD 5 NEW FIELDS
// ============================================================================
// BEFORE: Basic funnel with id, organizationId, name, description, isActive, funnelType, timestamps, stages
// AFTER: Extended with creator, visibility, psychology, versioning, auto-generation tracking

model Funnel {
  id               String        @id @default(cuid())
  organizationId   String
  name             String
  description      String?
  isActive         Boolean       @default(true)
  funnelType       String        @default("GENERAL")
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  // ========== NEW FIELDS (Phase 1: Funnel Wizard) ==========
  createdByUserId  String?                          // 작성자 ID (nullable, backward compat)
  visibility       String        @default("PUBLIC") @db.VarChar(10)  // PERSONAL | TEAM | PUBLIC
  autoGenerated    Boolean       @default(false)                      // AI 자동 생성 여부
  psychologyLens   String?       @db.VarChar(3)                       // L0-L10 심리학 렌즈
  templateVersion  Int           @default(1)                          // 버전 추적 (수정 이력)

  // Relations
  stages           FunnelStage[]
  organization     Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Indexes
  @@index([organizationId])
  @@index([organizationId, createdByUserId, createdAt(sort: Desc)], map: "idx_funnel_org_creator_time")
  @@index([organizationId, psychologyLens, visibility], map: "idx_funnel_org_psychology_visibility")
  @@index([organizationId, isActive, templateVersion(sort: Desc)], map: "idx_funnel_org_template_version")
}

// ============================================================================
// MODEL 2: FunnelSmsMessage — ADD 6 PSYCHOLOGY/PASONA FIELDS
// ============================================================================
// BEFORE: Basic message with id, funnelSmsId, order, daysAfter, content, msgType, timestamps
// AFTER: Extended with PASONA stages, psychology lens, segment targeting, A/B test variants

model FunnelSmsMessage {
  id                String    @id @default(cuid())
  funnelSmsId       String
  order             Int
  daysAfter         Int       @default(0)
  content           String    @db.Text
  msgType           String    @default("SMS") @db.VarChar(5)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // ========== NEW FIELDS (Phase 1: Psychology + PASONA) ==========
  pasonaStage       String?   @db.VarChar(20)       // PROBLEM | AFFINITY | SOLUTION | OFFER | NARROW | ACTION
  psychologyLens    String?   @db.VarChar(3)        // L0-L10 렌즈 (부재중, 가격, 차별성, 동반자, 건강, 타이밍, 자기투영, 재방문, 희소성, 즉시구매)
  psychology        String?   @db.VarChar(50)       // LOSS_AVERSION | SCARCITY | URGENCY | SOCIAL_PROOF | AUTHORITY | RECIPROCITY | CONSISTENCY | STORYTELLING | COMMUNITY_THINK | IMMEDIATE_ACTION
  segmentCode       String?   @db.VarChar(30)       // L0_INACTIVE | L1_PRICE | L3_COMPETITOR | L6_TIMING | 등 세그먼트 코드
  templateVariant   String?   @db.VarChar(50)       // A/B 테스트 변형 ID (예: "variant_A", "variant_B")
  dynamicVariables  Json?                           // 개인화 변수 맵 (예: {"name": "{{customerName}}", "product": "{{productName}}"})

  // Relations
  funnelSms         FunnelSms @relation(fields: [funnelSmsId], references: [id], onDelete: Cascade)

  // Constraints & Indexes
  @@unique([funnelSmsId, order])
  @@index([funnelSmsId])
  @@index([funnelSmsId, pasonaStage, order], map: "idx_funnel_sms_message_pasona")
  @@map("FunnelSmsMessage")
}

// ============================================================================
// MODEL 3: FunnelEmailMessage — ADD 7 PSYCHOLOGY/PASONA FIELDS
// ============================================================================
// BEFORE: Basic message with id, funnelEmailId, order, daysAfter, subject, bodyHtml, previewText, timestamps
// AFTER: Extended with PASONA stages, psychology lens, segment targeting, A/B test variants, HTML format preservation

model FunnelEmailMessage {
  id                String      @id @default(cuid())
  funnelEmailId     String
  order             Int
  daysAfter         Int         @default(0)
  subject           String
  bodyHtml          String      @db.Text
  previewText       String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  // ========== NEW FIELDS (Phase 1: Psychology + PASONA) ==========
  pasonaStage       String?     @db.VarChar(20)       // PROBLEM | AFFINITY | SOLUTION | OFFER | NARROW | ACTION
  psychologyLens    String?     @db.VarChar(3)        // L0-L10 렌즈
  psychology        String?     @db.VarChar(50)       // LOSS_AVERSION | SCARCITY | URGENCY | 등 심리학 기법
  segmentCode       String?     @db.VarChar(30)       // L0_INACTIVE | L1_PRICE | 등 세그먼트 코드
  templateVariant   String?     @db.VarChar(50)       // A/B 테스트 변형 ID
  dynamicVariables  Json?                             // 개인화 변수 맵
  preserveHtmlFormat Boolean   @default(true)        // HTML 형식 보존 여부 (기존 이메일 호환성)

  // Relations
  funnelEmail       FunnelEmail @relation(fields: [funnelEmailId], references: [id], onDelete: Cascade)

  // Constraints & Indexes
  @@unique([funnelEmailId, order])
  @@index([funnelEmailId])
  @@index([funnelEmailId, pasonaStage, order], map: "idx_funnel_email_message_pasona")
  @@map("FunnelEmailMessage")
}

