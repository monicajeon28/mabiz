generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
}

model Organization {
  id                         String                      @id @default(cuid())
  name                       String
  slug                       String                      @unique
  createdAt                  DateTime                    @default(now())
  updatedAt                  DateTime                    @updatedAt
  externalAffiliateProfileId Int?                        @unique
  plan                       String                      @default("FREE")
  status                     String                      @default("ACTIVE")
  contractRef                String?                     @unique(where: raw("(\"contractRef\" IS NOT NULL)"))
  adminMessages              AdminMessage[]
  aiCallLogs                 AiCallLog[]
  b2bProspects               B2BProspect[]
  campaignCosts              CampaignCost[]
  contacts                   Contact[]
  contactGroups              ContactGroup[]
  contactLensClassifications ContactLensClassification[]
  contactLensSequences       ContactLensSequence[]
  sentTransfers              ContactTransferLog[]        @relation("FromOrg")
  receivedTransfers          ContactTransferLog[]        @relation("ToOrg")
  affiliateSales             AffiliateSale[]
  b2bLandingPages            B2BLandingPage[]
  landingPages               CrmLandingPage[]
  marketingCampaigns         CrmMarketingCampaign[]      @relation("CrmMarketing")
  deltaConfigs               DeltaCampaignConfig[]       @relation("DeltaConfigs")
  documents                  Document[]
  executionLogs              ExecutionLog[]
  funnels                    Funnel[]
  goldMembers                GoldMember[]
  imageAssets                ImageAsset[]
  lensTemplates              LensTemplate[]
  memberDocuments            MemberDocument[]
  emailConfig                OrgEmailConfig?
  kakaoConfig                KakaoConfig?
  inviteTokens               OrgInviteToken[]
  smsConfig                  OrgSmsConfig?
  members                    OrganizationMember[]
  partners                   Partner[]
  partnerSuspensions         PartnerSuspension[]
  salesDocuments             SalesDocument[]
  // PHASE 7-3/4: Proactive Outreach Predictions
  churnPredictions           ChurnPrediction[]           @relation("ChurnPredictions")
  upsellOpportunities        UpsellOpportunity[]         @relation("UpsellOpportunities")
  winBackOpportunities       WinBackOpportunity[]        @relation("WinBackOpportunities")
  proactiveWorkflows         ProactiveWorkflow[]         @relation("ProactiveWorkflows")
  nextBestActions            NextBestAction[]            @relation("NextBestActions")
  salesDocApprovals          SalesDocumentApproval[]
  scheduledSmsList           ScheduledSms[]
  scriptPatterns             ScriptPattern[]
  shortLinks                 ShortLink[]
  smsTemplates               SmsTemplate[]
  contractTemplates          ContractTemplate[]
  contractInstances          ContractInstance[]
  contractTemplateAuditLogs  ContractTemplateAuditLog[]  @relation("ContractTemplateAuditLogs")
  l1PriceObjections          L1PriceObjectionAttempt[]
  l1ABTestVariants           L1ABTestVariant[]
  l1OptimizationScores       L1OptimizationScore[]
  marketingMessages          CrmMarketingMessage[]       @relation("CrmMarketingMessages")
  // Day 0-3 Sequences
  sequenceTemplates          SmsSequenceTemplate[]
  // Daily Reports
  dailyReports               DailyReport[]
  // A/B 테스트
  segmentAbTests             SegmentABTest[]             @relation("SegmentABTests")
  // Loop 4: Partner SMS Logs
  partnerSmsLogs             PartnerSmsLog[]
  partnerRiskScoreChanges    PartnerRiskScoreChange[]
  // Webhook Infrastructure
  webhookEvents              WebhookEvent[]
  // Commission Ledger
  commissionLedgers          CommissionLedger[]
  // Monthly Settlement
  monthlySettlements         MonthlySettlement[]
}

model OrgSmsConfig {
  id             String       @id @default(cuid())
  organizationId String       @unique
  aligoKey       String
  aligoUserId    String
  senderPhone    String
  isActive       Boolean      @default(true)
  senderVerified Boolean      @default(false)
  verifiedAt     DateTime?
  arsNum         String?
  reEngageMsg1   String?
  reEngageMsg2   String?
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model UserSmsConfig {
  id                String    @id @default(cuid())
  userId            String
  organizationId    String
  aligoKeyEncrypted String
  aligoUserId       String
  senderPhone       String
  senderVerified    Boolean   @default(false)
  verifiedAt        DateTime?
  isActive          Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@unique([userId, organizationId])
  @@index([organizationId])
}

model OrgEmailConfig {
  id                String       @id @default(cuid())
  organizationId    String       @unique
  senderName        String
  senderEmail       String
  smtpHost          String
  smtpPort          Int          @default(587)
  smtpUser          String
  smtpPassEncrypted String
  isActive          Boolean      @default(true)
  updatedAt         DateTime     @updatedAt
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model KakaoConfig {
  id             String       @id @default(cuid())
  organizationId String       @unique
  senderKey      String       @db.Text
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model OrganizationMember {
  id              String       @id @default(cuid())
  organizationId  String
  userId          String
  phone           String?
  passwordHash    String?
  role            String       @default("AGENT")
  displayName     String?
  isActive        Boolean      @default(true)
  email           String?
  emailSenderName String?
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
}

model GlobalAdmin {
  id           String   @id @default(cuid())
  phone        String?  @unique
  passwordHash String?
  displayName  String?
  createdAt    DateTime @default(now())
  userId       String?  @unique
  updatedAt    DateTime @updatedAt
}

model MabizSession {
  id             String   @id @default(cuid())
  memberId       String?
  adminId        String?
  organizationId String?
  role           String
  expiresAt      DateTime
  createdAt      DateTime @default(now())
  mallUserId     Int?
  updatedAt      DateTime @updatedAt

  @@index([memberId])
  @@index([adminId])
  @@index([mallUserId])
  @@map("MabizSession")
}

model Contact {
  id                               String    @id @default(cuid())
  phone                            String
  organizationId                   String
  name                             String
  email                            String?
  createdAt                        DateTime  @default(now())
  updatedAt                        DateTime  @updatedAt
  adminMemo                        String?
  affiliateCode                    String?
  assignedUserId                   String?
  bookingRef                       String?
  budgetRange                      String?
  cruiseInterest                   String?
  departureDate                    DateTime?
  lastContactedAt                  DateTime?
  leadScore                        Int       @default(0)
  optOutAt                         DateTime?
  productName                      String?
  purchasedAt                      DateTime?
  lastPaymentStatus                String?   @db.VarChar(20)
  lastPaymentAt                    DateTime?
  lastRefundedAt                   DateTime?
  paymentStatusNote                String?   @db.VarChar(255)
  reEngageCount                    Int       @default(0)
  reEngagedAt                      DateTime?
  sourceOrgId                      String?
  tags                             String[]  @default([])
  type                             String    @default("LEAD")
  utmSource                        String?
  deletedAt                        DateTime?
  partnerId                        String?
  status                           String?   @db.VarChar(20) // "ACTIVE", "INACTIVE", "PENDING_DELETION" 등
  phoneEncrypted                   String?
  phoneHash                        String?
  emailEncrypted                   String?
  nameEncrypted                    String?
  userId                           Int?
  user                             GmUser?   @relation("UserContacts", fields: [userId], references: [id], onDelete: SetNull)
  channel                          String    @default("direct")
  age                              Int?
  childrenCount                    Int       @default(0)
  gender                           String?
  lensMetadata                     Json?     @default("{\"decisionLevel\": 0, \"readinessScore\": 0}")
  maritalStatus                    String?
  segmentOverride                  String?
  segment                          String?
  recommendedProduct               String?
  marriageStatus                   String?   @db.VarChar(20)
  marriageDate                     DateTime?
  childrenAges                     Int[]     @default([])
  childrenPlanned                  String?   @db.VarChar(20)
  ageInYears                       Int?
  autoSegment                      String?   @default("unclassified") @db.VarChar(20)
  segmentUpdatedAt                 DateTime  @default(now()) @updatedAt
  socialProvider                   String?   @db.VarChar(20)
  // L2 Lens: 준비 불안도 평가 (Menu #48)
  anxietyScore                     Int       @default(0)
  anxietyCategory                  String?   @default("low") @db.VarChar(20) // low, medium, high
  preparationStage                 String?   @default("inquiry") @db.VarChar(50) // inquiry, visa_concern, health_concern, passport_concern, ready
  visaRequired                     Boolean   @default(false)
  passportDaysLeft                 Int?
  firstTimeCruise                  Boolean   @default(false)
  familyWithKids                   Boolean   @default(false)
  healthConcerns                   String? // 쉼표 구분: 배멀미, 당뇨, 고혈압 등
  anxietyAssessmentAt              DateTime?
  anxietySequenceStartedAt         DateTime?
  // L0 Lens: 부재중 고객 재활성화 (Menu #47)
  reactivationSegment              String?   @db.VarChar(20) // "3-6m", "6-12m", "1y+"
  reactivationLikelihood           Int       @default(0) // 0-100 점수
  lastCruiseDate                   DateTime?
  lastSatisfactionScore            Int?
  cruiseCount                      Int       @default(0)
  vipStatus                        String?   @db.VarChar(20) // "GOLD", "SILVER", null
  smsDay0Sent                      Boolean   @default(false)
  smsDay0SentAt                    DateTime?
  smsDay1Sent                      Boolean   @default(false)
  smsDay1SentAt                    DateTime?
  smsDay2Sent                      Boolean   @default(false)
  smsDay2SentAt                    DateTime?
  smsDay3Sent                      Boolean   @default(false)
  smsDay3SentAt                    DateTime?
  smsDay7Sent                      Boolean   @default(false)
  smsDay7SentAt                    DateTime?
  // L3 Lens: 차별성 미인지형 고객 (Menu #49)
  competitorMentioned              Boolean   @default(false)
  competitorNames                  String[]  @default([]) // ["Royal", "MSC", "Disney", ...]
  lastCompetitorMentionAt          DateTime?
  lastCompetitorName               String?   @db.VarChar(50)
  differentiationScore             Int       @default(0) // 0-100: 차별성 이해도
  hotelExperienceLevel             String?   @db.VarChar(20) // "none", "basic", "frequent", "regular"
  preparationFrameworkLevel        String?   @db.VarChar(20) // inquiry, understanding, convinced, booked
  differentiationResponseSent      Boolean   @default(false)
  lastDifferentiationResponseAt    DateTime?
  comparisonDocumentId             String?
  differentiationSequenceStartedAt DateTime?
  // L7 Lens: 동반자 설득 (Menu #50)
  familyComposition                String?   @db.VarChar(20) // "spouse", "parents", "friends", "mixed", "single"
  decisionMaker                    String?   @db.VarChar(20) // "self", "spouse", "parent", "friend"
  familyInfluenceScore             Int       @default(0) // 0-100: 가족 영향력
  companionPersuasionStage         String?   @default("inquiry") @db.VarChar(50) // inquiry, interested, hesitant, agreed, booked
  spouseName                       String?   @db.VarChar(50)
  spousePhone                      String?   @db.VarChar(20)
  spouseEngagement                 String?   @db.VarChar(20) // "not_contacted", "aware", "interested", "convinced"
  parentName                       String?   @db.VarChar(50)
  parentPhone                      String?   @db.VarChar(20)
  parentEngagement                 String?   @db.VarChar(20)
  friendName                       String?   @db.VarChar(50)
  friendPhone                      String?   @db.VarChar(20)
  friendEngagement                 String?   @db.VarChar(20)
  familyObjections                 String[]  @default([]) // 가족의 주요 이의사항
  companionSmsDay0Sent             Boolean   @default(false)
  companionSmsDay0SentAt           DateTime?
  companionSmsDay1Sent             Boolean   @default(false)
  companionSmsDay1SentAt           DateTime?
  companionSmsDay2Sent             Boolean   @default(false)
  companionSmsDay2SentAt           DateTime?
  companionSmsDay3Sent             Boolean   @default(false)
  companionSmsDay3SentAt           DateTime?
  familyAssessmentCompletedAt      DateTime?
  companionPersuasionStartedAt     DateTime?
  // L8 Lens: 재방문 습관화 (Menu #51)
  cruiseClubTier                   String?   @db.VarChar(20) // "bronze", "silver", "gold", "platinum"
  ltvTotal                         Float     @default(0) // 생명주기 가치 ($)
  nextCruiseRecommendation         String? // 추천 코스명
  lastCruiseSatisfactionScore      Int? // 만족도 (1-10)
  lastCruiseEndDate                DateTime? // 크루즈 종료일
  cruiseReturnInterestLevel        Int       @default(0) // 0-100: 재방문 의향
  returnVisitScheduledDate         DateTime? // 예정된 재방문 날짜
  smsDay10ReturnSent               Boolean   @default(false)
  smsDay10ReturnSentAt             DateTime?
  smsDay30ReturnSent               Boolean   @default(false)
  smsDay30ReturnSentAt             DateTime?
  smsDay60ReturnSent               Boolean   @default(false)
  smsDay60ReturnSentAt             DateTime?
  smsDay90ReturnSent               Boolean   @default(false)
  smsDay90ReturnSentAt             DateTime?
  ltvCalculatedAt                  DateTime?
  // L5 Lens: 자기투영 (Menu #55 - Part 1)
  selfProjectionScore              Int       @default(0) // 0-100: 자기투영도
  selfProjectionType               String?   @db.VarChar(50) // "personal_health", "family_health", "companion", "adventure"
  personalHealthCondition          String?   @db.VarChar(100) // 본인 건강 상태
  personalHealthConcern            String? // 쉼표 구분: 배멀미, 당뇨, 고혈압 등
  compoundHealthRisk               Boolean   @default(false) // 배우자 + 본인 health concern
  spouseHealthCondition            String?   @db.VarChar(100) // 배우자 건강 상태
  spouseHealthConcern              String? // 배우자 건강 문제
  familyHealthProfile              Json? // {"spouse": {...}, "children": [...]}
  selfProjectionAssessmentAt       DateTime?
  selfProjectionSequenceStartedAt  DateTime?

  // L6 Lens: 타이밍/손실회피 (Menu #55 - Part 2)
  timingUrgencyScore             Int       @default(0) // 0-100: 타이밍 긴급도
  timingType                     String?   @db.VarChar(30) // "price_deadline", "seat_scarcity", "age_window", "health_window"
  priceDeadlineDate              DateTime? // 가격 마감일
  seatAvailability               Int? // 남은 좌석 수
  ageRelevanceScore              Int       @default(0) // 0-100: 연령대별 의료 위험
  healthWindowStatus             String?   @db.VarChar(30) // "open", "closing_soon", "closed"
  lastDecisionWindow             DateTime? // 마지막 결정 기회 제시
  decisionWindowExpiresAt        DateTime? // 결정 윈도우 만료
  lossAversionPhrase             String? // "지금 신청하지 않으면..."
  medicalAuthorityCredential     String?   @db.VarChar(100) // 의료진 자격증명
  medicalAuthorityName           String?   @db.VarChar(50)
  timingUrgencyAssessmentAt      DateTime?
  timingUrgencySequenceStartedAt DateTime?
  l5l6CombinedScore              Int       @default(0) // 0-100: L5+L6 통합 점수
  l5l6MedicalRiskLevel           String?   @db.VarChar(20) // "low", "medium", "high", "critical"
  l5l6SmsDay0Sent                Boolean   @default(false)
  l5l6SmsDay0SentAt              DateTime?
  l5l6SmsDay1Sent                Boolean   @default(false)
  l5l6SmsDay1SentAt              DateTime?
  l5l6SmsDay2Sent                Boolean   @default(false)
  l5l6SmsDay2SentAt              DateTime?
  l5l6SmsDay3Sent                Boolean   @default(false)
  l5l6SmsDay3SentAt              DateTime?
  l5l6ConversionAt               DateTime?

  // L10 Lens: 즉시 구매 클로징 극대화 (Menu #56)
  closingStage               String?                     @default("initial") @db.VarChar(30) // "initial", "qualified", "ready_close", "closed"
  emotionalConnectionScore   Int                         @default(0) // 0-100: 감정적 연결도
  emotionalTriggers          String[]                    @default([]) // ["family_reunion", "dream_achieved", "adventure"]
  urgencyLevel               Int                         @default(0) // 0-100: 긴박감 수준
  urgencyType                String?                     @db.VarChar(30) // "price_deadline", "seat_availability", "seasonal"
  urgencyExpiresAt           DateTime? // 긴박감 만료 시간
  l10ClosingScore            Int                         @default(0) // 0-100: L10 클로징 준비도
  tripleChoiceOffered        Boolean                     @default(false)
  tripleChoiceSelectedAt     DateTime?
  tripleChoiceSelection      String?                     @db.VarChar(30) // "immediate", "next_day", "weekend"
  emotionalFinishSentAt      DateTime?
  emotionalFinishType        String?                     @db.VarChar(30) // "family_legacy", "dream_fulfillment", "experience_excellence"
  l10ClosingAttempts         Int                         @default(0)
  l10ConversionAt            DateTime?
  callLogs                   CallLog[]
  organization               Organization                @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  partner                    Partner?                    @relation(fields: [partnerId], references: [id])
  funnelState                ContactFunnelState?
  groups                     ContactGroupMember[]
  contactLensClassifications ContactLensClassification[]
  contactLensSequences       ContactLensSequence[]
  memos                      ContactMemo[]
  documents                  Document[]
  salesDocuments             SalesDocument[]
  shortLinks                 ShortLink[]
  shortLinkClicks            ShortLinkClick[]
  vipSequences               VipCareSequence[]
  marketingMessages          CrmMarketingMessage[]       @relation("CrmMarketingMessages")
  partnerSmsLogs             PartnerSmsLog[]
  // PHASE 7-3/4: Proactive Outreach Predictions
  churnPredictions           ChurnPrediction[]           @relation("ChurnPredictions")
  upsellOpportunities        UpsellOpportunity[]         @relation("UpsellOpportunities")
  winBackOpportunities       WinBackOpportunity[]        @relation("WinBackOpportunities")
  proactiveWorkflows         ProactiveWorkflow[]         @relation("ProactiveWorkflows")
  nextBestActions            NextBestAction[]            @relation("NextBestActions")

  // P0-1/2/3/4/5: Contact 상품/예약 FK 및 필드 추가
  cruiseProductId    Int?
  reservationId      Int?
  preferredCabinType String?
  quotedPrice        Int?
  priceAcceptedAt    DateTime?

  // P0-1/2/3/4/5: Relationships
  cruiseProduct CruiseProduct? @relation("ContactCruiseProducts", fields: [cruiseProductId], references: [id], onDelete: SetNull)
  reservation   GmReservation? @relation("ContactReservations", fields: [reservationId], references: [id], onDelete: SetNull)

  // P0-6: 고객 출처 분류 (2026-05-27)
  sourceType   String? @db.VarChar(30) // "user", "inquiry", "affiliate", "landing_page", "education", "gold_member"
  sourceId     String? @db.VarChar(50) // 원본 시스템의 ID
  signupMethod String? @db.VarChar(20) // User 출처만: "general", "kakao", "naver", "google"

  // Affiliate 전용 필드
  affiliateLinkId    String? @db.VarChar(50) // AffiliateLead.linkId
  affiliateManagerId String? @db.VarChar(50) // AffiliateLead.managerId (본사)
  affiliateAgentId   String? @db.VarChar(50) // AffiliateLead.agentId (판매원)

  // Inquiry 전용 필드
  inquiryProductCode String? @db.VarChar(50) // CruiseProductInquiry.productCode

  @@unique([phone, organizationId])
  @@unique([bookingRef, organizationId], map: "uq_contact_booking_org") // P0-ISS-02: UPSERT 멱등성
  @@unique([email, organizationId], map: "uq_contact_email_org") // Webhook: Customer email upsert
  @@index([organizationId])
  @@index([type])
  @@index([assignedUserId])
  @@index([partnerId])
  @@index([deletedAt])
  @@index([userId])
  @@index([organizationId, assignedUserId], map: "idx_contact_org_assigned")
  @@index([organizationId, channel], map: "idx_contact_org_channel")
  @@index([organizationId, type], map: "idx_contact_org_type")
  @@index([organizationId, lastPaymentStatus], map: "idx_contact_org_payment_status")
  @@index([organizationId, autoSegment], map: "idx_contact_org_segment")
  @@index([marriageDate], map: "idx_contact_marriage_date")
  @@index([childrenAges], map: "idx_contact_children_ages")
  @@index([organizationId, socialProvider], map: "idx_contact_org_social_provider")
  @@index([organizationId, reactivationSegment], map: "idx_contact_reactivation_segment")
  @@index([organizationId, reactivationLikelihood], map: "idx_contact_reactivation_likelihood")
  @@index([organizationId, lastCruiseDate], map: "idx_contact_last_cruise_date")
  @@index([organizationId, smsDay0Sent, smsDay1Sent, smsDay2Sent, smsDay3Sent], map: "idx_contact_reactivation_sms_status")
  @@index([organizationId, competitorMentioned], map: "idx_contact_competitor_mentioned")
  @@index([organizationId, differentiationScore], map: "idx_contact_differentiation_score")
  @@index([organizationId, lastCompetitorMentionAt], map: "idx_contact_last_competitor_mention")
  @@index([organizationId, cruiseClubTier], map: "idx_contact_cruise_club_tier")
  @@index([organizationId, ltvTotal], map: "idx_contact_ltv_total")
  @@index([organizationId, lastCruiseEndDate], map: "idx_contact_last_cruise_end_date")
  @@index([organizationId, cruiseCount], map: "idx_contact_cruise_count")
  // L7 Lens indexes
  @@index([organizationId, familyComposition], map: "idx_contact_family_composition")
  @@index([organizationId, decisionMaker], map: "idx_contact_decision_maker")
  @@index([organizationId, familyInfluenceScore], map: "idx_contact_family_influence")
  @@index([organizationId, companionPersuasionStage], map: "idx_contact_companion_stage")
  @@index([organizationId, spouseEngagement], map: "idx_contact_spouse_engagement")
  @@index([organizationId, companionSmsDay0Sent, companionSmsDay1Sent, companionSmsDay2Sent, companionSmsDay3Sent], map: "idx_contact_companion_sms_status")
  // L5 Lens: 자기투영 indexes
  @@index([organizationId, selfProjectionScore], map: "idx_contact_self_projection_score")
  @@index([organizationId, selfProjectionType], map: "idx_contact_self_projection_type")
  @@index([organizationId, compoundHealthRisk], map: "idx_contact_compound_health_risk")
  @@index([organizationId, selfProjectionSequenceStartedAt], map: "idx_contact_self_projection_sequence")
  // L6 Lens: 타이밍/손실회피 indexes
  @@index([organizationId, timingUrgencyScore], map: "idx_contact_timing_urgency_score")
  @@index([organizationId, timingType], map: "idx_contact_timing_type")
  @@index([organizationId, priceDeadlineDate], map: "idx_contact_price_deadline")
  @@index([organizationId, decisionWindowExpiresAt], map: "idx_contact_decision_window_expires")
  @@index([organizationId, l5l6CombinedScore], map: "idx_contact_l5l6_combined_score")
  @@index([organizationId, l5l6MedicalRiskLevel], map: "idx_contact_l5l6_medical_risk")
  @@index([organizationId, l5l6SmsDay0Sent, l5l6SmsDay1Sent, l5l6SmsDay2Sent, l5l6SmsDay3Sent], map: "idx_contact_l5l6_sms_status")
  @@index([organizationId, l5l6ConversionAt], map: "idx_contact_l5l6_conversion")
  // L10 Lens indexes
  @@index([organizationId, closingStage], map: "idx_contact_closing_stage")
  @@index([organizationId, emotionalConnectionScore], map: "idx_contact_emotional_connection")
  @@index([organizationId, urgencyLevel], map: "idx_contact_urgency_level")
  @@index([organizationId, l10ClosingScore], map: "idx_contact_l10_closing_score")
  @@index([organizationId, tripleChoiceOffered], map: "idx_contact_triple_choice_offered")
  @@index([organizationId, urgencyExpiresAt], map: "idx_contact_urgency_expires")
  @@index([organizationId, l10ConversionAt], map: "idx_contact_l10_conversion")
  // P0-1/2/3/4/5: Product FK indexes
  @@index([organizationId, cruiseProductId], map: "idx_contact_cruise_product_id")
  @@index([organizationId, reservationId], map: "idx_contact_reservation_id")
  @@index([organizationId, quotedPrice], map: "idx_contact_quoted_price")
  @@index([organizationId, priceAcceptedAt], map: "idx_contact_price_accepted")
  // P0-6 인덱스
  @@index([organizationId, sourceType], map: "idx_contact_org_source_type")
