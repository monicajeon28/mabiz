generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
}

model Organization {
  id                         String                  @id @default(cuid())
  name                       String
  slug                       String                  @unique
  createdAt                  DateTime                @default(now())
  updatedAt                  DateTime                @updatedAt
  externalAffiliateProfileId Int?                    @unique
  plan                       String                  @default("FREE")
  status                     String                  @default("ACTIVE")
  contractRef                String?                 @unique(where: raw("(\"contractRef\" IS NOT NULL)"))
  adminMessages              AdminMessage[]
  aiCallLogs                 AiCallLog[]
  contacts                   Contact[]
  contactGroups              ContactGroup[]
  sentTransfers              ContactTransferLog[]    @relation("FromOrg")
  receivedTransfers          ContactTransferLog[]    @relation("ToOrg")
  affiliateSales             AffiliateSale[]
  landingPages               CrmLandingPage[]
  documents                  Document[]
  funnels                    Funnel[]
  goldMembers                GoldMember[]
  imageAssets                ImageAsset[]
  memberDocuments            MemberDocument[]
  emailConfig                OrgEmailConfig?
  inviteTokens               OrgInviteToken[]
  smsConfig                  OrgSmsConfig?
  members                    OrganizationMember[]
  partners                   Partner[]
  salesDocuments             SalesDocument[]
  salesDocApprovals          SalesDocumentApproval[]
  scheduledSmsList           ScheduledSms[]
  scriptPatterns             ScriptPattern[]
  shortLinks                 ShortLink[]
  smsTemplates               SmsTemplate[]
}

model OrgSmsConfig {
  id             String       @id @default(cuid())
  organizationId String       @unique
  aligoKey       String
  aligoUserId    String
  senderPhone    String
  isActive       Boolean      @default(true)
  senderVerified Boolean      @default(false)
  verifiedAt     DateTime?
  arsNum         String?
  reEngageMsg1   String?
  reEngageMsg2   String?
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model OrgEmailConfig {
  id                String       @id @default(cuid())
  organizationId    String       @unique
  senderName        String
  senderEmail       String
  smtpHost          String
  smtpPort          Int          @default(587)
  smtpUser          String
  smtpPassEncrypted String
  isActive          Boolean      @default(true)
  updatedAt         DateTime     @updatedAt
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model OrganizationMember {
  id             String       @id @default(cuid())
  organizationId String
  userId         String
  phone          String?
  passwordHash   String?
  role           String       @default("AGENT")
  displayName    String?
  isActive       Boolean      @default(true)
  email          String?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
}

model GlobalAdmin {
  id           String   @id @default(cuid())
  phone        String?  @unique
  passwordHash String?
  displayName  String?
  createdAt    DateTime @default(now())
  userId       String?  @unique
  updatedAt    DateTime @updatedAt
}

model MabizSession {
  id             String   @id @default(cuid())
  memberId       String?
  adminId        String?
  organizationId String?
  role           String
  expiresAt      DateTime
  createdAt      DateTime @default(now())
  mallUserId     Int?
  updatedAt      DateTime @updatedAt

  @@index([memberId])
  @@index([adminId])
  @@index([mallUserId])
  @@map("MabizSession")
}

model Contact {
  id              String               @id @default(cuid())
  phone           String
  organizationId  String
  name            String
  email           String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  adminMemo       String?
  affiliateCode   String?
  assignedUserId  String?
  bookingRef      String?
  budgetRange     String?
  cruiseInterest  String?
  departureDate   DateTime?
  lastContactedAt DateTime?
  leadScore       Int                  @default(0)
  optOutAt        DateTime?
  productName     String?
  purchasedAt     DateTime?
  reEngageCount   Int                  @default(0)
  reEngagedAt     DateTime?
  sourceOrgId     String?
  tags            String[]             @default([])
  type            String               @default("LEAD")
  utmSource       String?
  deletedAt       DateTime?
  partnerId       String?
  phoneEncrypted  String?
  phoneHash       String?
  emailEncrypted  String?
  nameEncrypted   String?
  userId          Int?
  channel         String               @default("direct")
  callLogs        CallLog[]
  organization    Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  partner         Partner?             @relation(fields: [partnerId], references: [id])
  funnelState     ContactFunnelState?
  groups          ContactGroupMember[]
  memos           ContactMemo[]
  documents       Document[]
  salesDocuments  SalesDocument[]
  shortLinks      ShortLink[]
  shortLinkClicks ShortLinkClick[]
  vipSequences    VipCareSequence[]

  @@unique([phone, organizationId])
  @@index([organizationId])
  @@index([type])
  @@index([assignedUserId])
  @@index([partnerId])
  @@index([deletedAt])
  @@index([organizationId, assignedUserId], map: "idx_contact_org_assigned")
  @@index([organizationId, channel], map: "idx_contact_org_channel")
  @@index([organizationId, type], map: "idx_contact_org_type")
}

model ContactGroup {
  id             String               @id @default(cuid())
  organizationId String
  name           String
  description    String?
  color          String?              @default("#6B7280")
  funnelId       String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  ownerId        String?
  organization   Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  members        ContactGroupMember[]
  landingPages   CrmLandingPage[]
  tokens         GroupToken[]

  @@index([organizationId])
  @@index([ownerId])
}

model GroupToken {
  id             String       @id @default(cuid())
  groupId        String
  expiresAt      DateTime
  active         Boolean      @default(true)
  createdAt      DateTime     @default(now())
  group          ContactGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([groupId])
  @@index([expiresAt])
}

model ContactGroupMember {
  id        String       @id @default(cuid())
  groupId   String
  contactId String
  addedAt   DateTime     @default(now())
  contact   Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)
  group     ContactGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([groupId, contactId])
}

model CallLog {
  id              String    @id @default(cuid())
  contactId       String
  userId          String
  content         String?
  result          String?
  duration        Int?
  convictionScore Int?
  nextAction      String?
  scheduledAt     DateTime?
  createdAt       DateTime  @default(now())
  contact         Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([contactId])
  @@index([userId])
  @@index([contactId, createdAt(sort: Desc)])
}

model ContactMemo {
  id        String   @id @default(cuid())
  contactId String
  userId    String
  content   String
  createdAt DateTime @default(now())
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([contactId])
}

model CrmLandingPage {
  id                String                   @id @default(cuid())
  organizationId    String
  title             String
  slug              String
  htmlContent       String?
  isActive          Boolean                  @default(true)
  isPublic          Boolean                  @default(true)
  viewCount         Int                      @default(0)
  autoFunnelId      String?
  groupId           String?
  commentEnabled    Boolean                  @default(false)
  group             ContactGroup?            @relation(fields: [groupId], references: [id], onDelete: SetNull)
  createdAt         DateTime                 @default(now())
  createdByUserId   String?
  updatedAt         DateTime                 @updatedAt
  description       String?
  category          String?
  pageGroup         String?
  buttonTitle       String?
  completionPageUrl String?
  headerScript      String?
  exposureTitle     String?
  exposureImage     String?
  infoCollection    Boolean                  @default(false)
  editorMode        String                   @default("html")
  formConfig        Json?
  paymentEnabled    Boolean                  @default(false)
  paymentType       String?
  productName       String?
  productPrice      Int?
  cycleDay          Int?
  expireDate        DateTime?
  regEmailEnabled   Boolean                  @default(false)
  regEmailSubject   String?
  regEmailContent   String?
  comments          CrmLandingComment[]
  organization      Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  registrations     CrmLandingRegistration[]
  shares            CrmLandingShare[]

  @@unique([slug, organizationId])
  @@index([organizationId])
  @@index([organizationId, createdByUserId, createdAt])
  @@map("CrmLandingPage")
}

model CrmLandingShare {
  id             String         @id @default(cuid())
  landingPageId  String
  sharedToOrgId  String
  sharedByUserId String
  sharedByOrgId  String
  sharedByName   String
  isGlobal       Boolean        @default(false)
  createdAt      DateTime       @default(now())
  landingPage    CrmLandingPage @relation(fields: [landingPageId], references: [id], onDelete: Cascade)

  @@unique([landingPageId, sharedToOrgId])
  @@index([sharedToOrgId])
  @@index([sharedByOrgId])
  @@map("CrmLandingShare")
}

model CrmLandingPageImage {
  id            String   @id @default(dbgenerated("gen_random_uuid()"))
  landingPageId String
  imageAssetId  String
  sortOrder     Int      @default(0)
  altText       String?
  createdAt     DateTime @default(now())

  @@unique([landingPageId, imageAssetId])
  @@index([landingPageId, sortOrder])
  @@map("CrmLandingPageImage")
}

model CrmLandingComment {
  id              String         @id @default(cuid())
  landingPageId   String
  authorName      String
  content         String
  passwordHash    String?
  isAutoGenerated Boolean        @default(false)
  createdAt       DateTime       @default(now())
  landingPage     CrmLandingPage @relation(fields: [landingPageId], references: [id], onDelete: Cascade)

  @@index([landingPageId])
  @@map("CrmLandingComment")
}

model CrmLandingRegistration {
  id            String         @id @default(cuid())
  landingPageId String
  name          String
  phone         String
  email         String?
  utmSource     String?
  utmMedium     String?
  utmCampaign   String?
  metadata      Json?
  funnelStarted Boolean        @default(false)
  createdAt     DateTime       @default(now())
  landingPage   CrmLandingPage @relation(fields: [landingPageId], references: [id], onDelete: Cascade)

  @@unique([landingPageId, phone])
  @@index([landingPageId])
  @@index([utmSource, utmMedium])
  @@map("CrmLandingRegistration")
}

model Funnel {
  id             String        @id @default(cuid())
  organizationId String
  name           String
  description    String?
  isActive       Boolean       @default(true)
  funnelType     String        @default("GENERAL")
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  stages         FunnelStage[]
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model FunnelStage {
  id             String  @id @default(cuid())
  funnelId       String
  order          Int
  name           String
  triggerType    String  @default("DAYS_AFTER")
  triggerOffset  Int     @default(0)
  channel        String  @default("SMS")
  messageContent String?
  linkUrl        String?
  funnel         Funnel  @relation(fields: [funnelId], references: [id], onDelete: Cascade)

  @@index([funnelId])
  @@map("CrmFunnelStage")
}

model VipCareSequence {
  id           String       @id @default(cuid())
  contactId    String
  funnelId     String?
  startDate    DateTime
  status       String       @default("ACTIVE")
  currentStage Int          @default(0)
  createdAt    DateTime     @default(now())
  pausedAt     DateTime?
  pausedBy     String?
  logs         VipCareLog[]
  contact      Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([contactId])
  @@index([status])
}

model VipCareLog {
  id          String          @id @default(cuid())
  sequenceId  String
  stageOrder  Int
  scheduledAt DateTime
  sentAt      DateTime?
  status      String          @default("PENDING")
  content     String?
  channel     String?         @default("SMS")
  sequence    VipCareSequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)

  @@index([sequenceId])
  @@index([scheduledAt])
  @@index([status, scheduledAt], map: "idx_vipcarelog_status_scheduled")
}

model SmsTemplate {
  id             String        @id @default(cuid())
  organizationId String?
  category       String
  title          String
  content        String
  triggerType    String?
  triggerOffset  Int?
  isSystem       Boolean       @default(false)
  usageCount     Int           @default(0)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([category])
}

model SmsOptOut {
  id         String   @id @default(cuid())
  phone      String   @unique
  optedOutAt DateTime @default(now())
  reason     String?
}

model SmsLog {
  id             String   @id @default(cuid())
  organizationId String
  contactId      String?
  phone          String
  contentPreview String
  status         String   @default("SENT")
  blockReason    String?
  resultCode     String?
  msgId          String?
  channel        String   @default("FUNNEL")
  sentAt         DateTime @default(now())

  @@index([organizationId, sentAt])
  @@index([contactId, sentAt])
  @@map("CrmSmsLog")
}

model SalesPlaybook {
  id           String   @id @default(cuid())
  type         String
  title        String
  content      String
  priority     Int      @default(0)
  isActive     Boolean  @default(true)
  scriptTab    String   @default("GENERAL")
  productCode  String   @default("ALL")
  sectionOrder Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([type])
}

model ImageCache {
  id                 Int       @id @default(autoincrement())
  driveFileId        String    @unique
  path               String
  fileName           String
  folder             String
  title              String
  tags               String[]
  mimeType           String?
  fileSize           Int?
  driveUrl           String?
  thumbnailUrl       String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  syncedAt           DateTime  @default(now())
  webpUrl            String?
  webpFileId         String?
  webpSize           Int?
  cloudinaryUrl      String?
  cloudinaryPublicId String?
  cloudinarySyncedAt DateTime?
  deletedAt          DateTime?

  @@index([folder])
  @@index([title])
  @@index([syncedAt])
  @@index([cloudinaryUrl])
  @@index([webpUrl])
}

model CallRecording {
  id             String   @id @default(cuid())
  callLogId      String?
  contactId      String
  userId         String
  fileName       String
  fileUrl        String?
  durationSec    Int?
  transcriptText String?
  aiFeedback     String?
  aiScore        Int?
  createdAt      DateTime @default(now())

  @@index([contactId])
  @@index([userId])
}

model CrmLandingView {
  id            String   @id @default(cuid())
  landingPageId String
  ipHash        String
  viewedAt      DateTime @default(now())

  @@unique([landingPageId, ipHash])
  @@index([viewedAt])
  @@map("CrmLandingView")
}

model PayAppPayment {
  id             String    @id @default(cuid())
  orderId        String    @unique
  amount         Int
  customerName   String
  customerPhone  String
  status         String    @default("pending")
  landingPageId  String?
  paidAt         DateTime?
  createdAt      DateTime  @default(now())
  createdByUserId String?
  productName    String?
  customerEmail  String?
  mulNo          String?
  payType        String?
  cardName       String?
  cstUrl         String?
  refundedAt     DateTime?
  refundAmount   Int       @default(0)
  refundReason   String?
  metadata       Json?
  organizationId String?
  subscriptionId String?

  @@index([customerPhone])
  @@index([landingPageId])
  @@index([mulNo])
  @@index([status])
  @@index([organizationId, createdByUserId, createdAt])
  @@map("CrmPayAppPayment")
}

model PayAppSubscription {
  id             String   @id @default(cuid())
  organizationId String
  rebillNo       String
  goodname       String
  goodprice      Int
  customerName   String
  customerPhone  String
  customerEmail  String?
  cycleDay       Int      @default(1)
  expireDate     DateTime
  status         String   @default("pending")
  payUrl         String?
  landingPageId  String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("CrmPayAppSubscription")
}

model ScheduledSms {
  id              String       @id @default(cuid())
  organizationId  String
  contactId       String?
  groupId         String?
  message         String
  scheduledAt     DateTime
  status          String       @default("PENDING")
  sentAt          DateTime?
  sentCount       Int          @default(0)
  failedCount     Int          @default(0)
  createdByUserId String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  pausedAt        DateTime?
  pausedBy        String?
  failureReason   String?
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, status, scheduledAt])
  @@index([scheduledAt, status])
  @@map("ScheduledSms")
}

model OrgInviteToken {
  id              String       @id @default(cuid())
  organizationId  String
  token           String       @unique
  role            String       @default("AGENT")
  note            String?
  expiresAt       DateTime
  usedAt          DateTime?
  usedByUserId    String?
  agreedToTerms   Boolean      @default(false)
  createdByUserId String?
  createdAt       DateTime     @default(now())
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([expiresAt])
  @@map("OrgInviteToken")
}

model ContactTransferLog {
  id            String        @id @default(cuid())
  contactId     String
  fromOrgId     String
  toOrgId       String?
  toUserId      String?
  newContactId  String?
  transferType  String
  transferredBy String
  note          String?
  createdAt     DateTime      @default(now())
  fromOrg       Organization  @relation("FromOrg", fields: [fromOrgId], references: [id], onDelete: Cascade)
  toOrg         Organization? @relation("ToOrg", fields: [toOrgId], references: [id])

  @@index([contactId])
  @@index([fromOrgId])
  @@index([toOrgId])
  @@index([transferredBy])
  @@map("ContactTransferLog")
}

model ContactChangeLog {
  id        Int       @id @default(autoincrement())
  contactId String?
  gmUserId  Int?
  field     String
  oldValue  String?
  newValue  String?
  reason    String?
  changedBy String
  changedAt DateTime  @default(now())

  @@index([gmUserId])
  @@index([contactId])
  @@map("ContactChangeLog")
}

model AffiliateSale {
  id                String          @id @default(cuid())
  organizationId    String
  affiliateCode     String
  affiliateUserId   String?
  productName       String
  saleAmount        Int
  commissionRate    Int             @default(0)
  commissionAmount  Int             @default(0)
  status            String          @default("PENDING")
  travelCompletedAt DateTime?
  paidAt            DateTime?
  customerPhone     String?
  orderId           String?         @unique
  sourceWebhook     String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  organization      Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  salesDocuments    SalesDocument[]

  @@index([organizationId])
  @@index([affiliateCode])
  @@index([affiliateUserId])
  @@index([status])
  @@map("CrmAffiliateSale")
}

model AiCallLog {
  id             String          @id @default(cuid())
  organizationId String
  agentUserId    String
  productType    String
  personaType    String?
  rawTextMasked  String
  converted      Boolean         @default(false)
  durationSec    Int?
  analysisStatus String          @default("PENDING")
  productCode    String          @default("ALL")
  uploadedAt     DateTime        @default(now())
  analysis       AiCallAnalysis?
  organization   Organization    @relation(fields: [organizationId], references: [id])

  @@map("AiCallLog")
}

model AiCallAnalysis {
  id                String    @id @default(cuid())
  callLogId         String    @unique
  personaDetected   String
  personaConfidence Float     @default(0)
  scores            Json
  keyPhrases        Json
  strengths         Json
  weaknesses        Json
  objectionTypes    Json
  goldValueScore    Float?
  analyzedAt        DateTime  @default(now())
  callLog           AiCallLog @relation(fields: [callLogId], references: [id], onDelete: Cascade)

  @@map("AiCallAnalysis")
}

model ScriptPattern {
  id             String       @id @default(cuid())
  organizationId String
  productType    String
  personaType    String
  category       String
  objectionType  String?
  patternText    String
  exampleCall    String?
  useCount       Int          @default(0)
  conversionRate Float        @default(0)
  productCode    String       @default("ALL")
  status         String       @default("DRAFT")
  approvedBy     String?
  approvedAt     DateTime?
  extractedAt    DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@map("ScriptPattern")
}

model ShortLink {
  id             String           @id @default(cuid())
  organizationId String
  code           String           @unique
  targetUrl      String
  title          String?
  contactId      String?
  category       String?
  autoGroupId    String?
  clickCount     Int              @default(0)
  isActive       Boolean          @default(true)
  createdAt      DateTime         @default(now())
  contact        Contact?         @relation(fields: [contactId], references: [id])
  organization   Organization     @relation(fields: [organizationId], references: [id])
  clicks         ShortLinkClick[]

  @@map("ShortLink")
}

model ShortLinkClick {
  id        String    @id @default(cuid())
  linkId    String
  contactId String?
  clickedAt DateTime  @default(now())
  userAgent String?
  contact   Contact?  @relation(fields: [contactId], references: [id])
  link      ShortLink @relation(fields: [linkId], references: [id], onDelete: Cascade)

  @@map("ShortLinkClick")
}

model NewsShortLink {
  id             String   @id @default(cuid())
  organizationId String?
  shortCode      String   @unique
  title          String
  url            String
  isActive       Boolean  @default(true)
  syncedAt       DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("NewsShortLink")
}

model NewsSyncState {
  id           String   @id @default("global")
  lastSyncedAt DateTime @default(now())

  @@map("NewsSyncState")
}

model Payment {
  id                  Int           @id @default(autoincrement())
  orderId             String        @unique
  productName         String?
  amount              Int
  buyerName           String
  buyerEmail          String?
  buyerTel            String
  pgProvider          String?
  pgTransactionId     String?
  affiliateCode       String?
  paidAt              DateTime?
  cancelledAt         DateTime?
  metadata            Json?
  status              PaymentStatus @default(pending)
  affiliateMallUserId String?
  currency            String        @default("KRW")
  pgMid               String?
  productCode         String?
  refundAmount        Int?
  refundReason        String?
  saleId              Int?          @unique
  completedAt         DateTime?
  failedAt            DateTime?
  failureReason       String?
  refundedAt          DateTime?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @default(now())

  @@index([affiliateCode])
  @@index([buyerTel])
  @@index([orderId])
  @@index([pgTransactionId])
  @@map("Payment")
}

model SalesDocument {
  id              String                  @id @default(cuid())
  organizationId  String
  documentType    String
  status          String                  @default("DRAFT")
  orderId         String?
  affiliateSaleId String?
  contactId       String?
  generatedData   Json
  filePath        String?
  approvedBy      String?
  approvedAt      DateTime?
  rejectedReason  String?
  createdBy       String
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  affiliateSale   AffiliateSale?          @relation(fields: [affiliateSaleId], references: [id])
  contact         Contact?                @relation(fields: [contactId], references: [id])
  organization    Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  approvals       SalesDocumentApproval[]

  @@index([organizationId, documentType])
  @@index([organizationId, status])
  @@index([orderId])
  @@map("SalesDocument")
}

model SalesDocumentApproval {
  id             String        @id @default(cuid())
  documentId     String
  organizationId String
  requestedBy    String
  approvedBy     String?
  status         String        @default("PENDING")
  requestNote    String?
