/// 중앙 감시 로그: 모든 PII 접근, 수정, 삭제 기록
/// 규정 준수 증거용 - 5년 보관, 월별 파티셔닝
model AuditLog {
  id BigInt @id @default(autoincrement())

  // 식별정보
  organizationId String? @db.VarChar(255)
  userId         String? @db.VarChar(255)
  sessionId      String? @db.VarChar(255)
  ipAddress      String? @db.VarChar(45)
  userAgent      String? @db.Text

  // 액션 정보
  action       String  @db.VarChar(50) // "READ", "WRITE", "DELETE", "EXPORT", "LOGIN"
  resourceType String  @db.VarChar(100) // "Contact", "OrganizationMember", "Document"
  resourceId   String? @db.VarChar(255)

  // PII 필드 추적
  piiFieldsAccessed String[] @default([]) // ["phone", "email", "name"]
  piiValuesModified Json? // Before/after values (masked)

  // 결과
  status       String  @default("SUCCESS") @db.VarChar(20) // SUCCESS, FAILED, DENIED
  errorMessage String? @db.Text

  // 목적/근거
  purpose           String? @db.VarChar(255) // "Business", "Compliance", "Support"
  reasonDescription String? @db.Text

  // 타이밍
  createdAt  DateTime @default(now())
  durationMs Int?

  // 인덱싱
  @@index([organizationId, createdAt])
  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@index([status, createdAt])
  @@index([resourceType, resourceId])
  @@map("AuditLog")
}

