// Day 0-3 Sequence Template (Sequence configuration)
model SmsSequenceTemplate {
  id             String  @id @default(cuid())
  organizationId String
  name           String // "크루즈 골드 Day 0-3"
  description    String?
  productCode    String? // "CRUISE_GOLD", "RENTAL", etc.
  psychologyLens String? // "L0", "L1", "L6", "L10", etc.
  sequenceType   String  @default("DAY_0_3") // "DAY_0_3", "DAY_7_RECOVERY", etc.

  // Day-specific template references
  day0TemplateId String?
  day1TemplateId String?
  day2TemplateId String?
  day3TemplateId String?

  // Delay configuration (in minutes)
  day0Delay Int @default(0) // 0-1440
  day1Delay Int @default(1440) // 1 day
  day2Delay Int @default(2880) // 2 days
  day3Delay Int @default(4320) // 3 days

  // Conditional rules
  conditions Json? // { "productCode": ["CRUISE_GOLD"], "lens": ["L6", "L10"], "minValue": 5000000 }
  triggerOn  String @default("PURCHASE") // "PURCHASE", "OBJECTION", "INQUIRY"

  // Performance metrics
  totalSent      Int @default(0)
  totalOpened    Int @default(0)
  totalClicked   Int @default(0)
  totalConverted Int @default(0)

  // Status
  status          String    @default("DRAFT") // "DRAFT", "ACTIVE", "PAUSED", "ARCHIVED"
  isSystem        Boolean   @default(false)
  createdByUserId String?
  deployedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  organization Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  instances    ContactSequenceInstance[] @relation("TemplateInstances")
  variants     SmsSequenceVariant[]      @relation("TemplateVariants")

  @@index([organizationId, status])
  @@index([organizationId, productCode])
  @@index([organizationId, psychologyLens])
  @@index([organizationId, triggerOn])
  @@index([organizationId, status, deployedAt])
  @@map("SmsSequenceTemplate")
}

// Contact Sequence Instance (tracks active sequences per contact)
model ContactSequenceInstance {
  id             String @id @default(cuid())
  organizationId String
  contactId      String
  sequenceId     String

  // Progress tracking (sent timestamps)
  day0SentAt DateTime?
  day1SentAt DateTime?
  day2SentAt DateTime?
  day3SentAt DateTime?

  // Open tracking
  day0OpenedAt DateTime?
  day1OpenedAt DateTime?
  day2OpenedAt DateTime?
  day3OpenedAt DateTime?

  // Conversion tracking
  convertedAt   DateTime?
  conversionDay Int? // which day user converted (0, 1, 2, 3, or null)

  // Status
  status        String    @default("ACTIVE") // "ACTIVE", "PAUSED", "COMPLETED", "FAILED"
  nextSendAt    DateTime?
  failureReason String?
  pausedAt      DateTime?
  pausedBy      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  template SmsSequenceTemplate @relation("TemplateInstances", fields: [sequenceId], references: [id], onDelete: Cascade)

  @@unique([contactId, sequenceId], map: "uq_contact_sequence")
  @@index([organizationId, status, nextSendAt], map: "idx_instance_org_status_next_send")
  @@index([organizationId, status])
  @@index([contactId, status])
  @@index([sequenceId, status])
  @@index([nextSendAt, status], map: "idx_instance_next_send_cron")
  @@map("ContactSequenceInstance")
}

// SMS Sequence Variant (A/B test variants per day)
model SmsSequenceVariant {
  id          String @id @default(cuid())
  sequenceId  String
  variantCode String // "A", "B", "C", "D", "E"
  day         Int // 0, 1, 2, 3

  messageContent String // Actual SMS text
  psychology     String? // "LOSS_AVERSION", "SCARCITY", "URGENCY", etc.
  lensName       String? // "L6 타이밍", "L10 클로징"
  pasonaStage    String? // "P", "A", "S", "O", "N"

  // Performance metrics
  sentCount    Int @default(0)
  openCount    Int @default(0)
  clickCount   Int @default(0)
  convertCount Int @default(0)

  isWinner Boolean @default(false) // A/B test winner

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  template SmsSequenceTemplate @relation("TemplateVariants", fields: [sequenceId], references: [id], onDelete: Cascade)

  @@unique([sequenceId, variantCode, day], map: "uq_sequence_variant_day")
  @@index([sequenceId])
  @@index([sequenceId, day])
  @@map("SmsSequenceVariant")
}

