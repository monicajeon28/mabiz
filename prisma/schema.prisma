// Menu #57: PartnerPerformance Model (주간/월간 KPI)
model PartnerPerformance {
  id        String @id @default(cuid())
  partnerId String
  year      Int
  month     Int
  week      Int? // null일 경우 월 단위

  // 기본 KPI
  totalCalls       Int    @default(0)
  appointmentsMade Int    @default(0)
  salesClosed      Int    @default(0)
  revenue          BigInt @default(0) // 단위: 원

  // 전환율 지표 (%)
  callToAppointmentRate Float? // (appointmentsMade / totalCalls) * 100
  appointmentToSaleRate Float? // (salesClosed / appointmentsMade) * 100
  overallConversionRate Float? // (salesClosed / totalCalls) * 100

  // CPA 및 LTV
  costPerAcquisition BigInt? // 단위: 원
  lifetimeValue      BigInt? // 단위: 원

  // 자동화 상태
  automationScore Int @default(0) // 0-100

  // 위험 신호
  riskScore Int      @default(0) // 0-100
  riskFlags String[] @default([]) // ["lowPerformance", "churnIndicator", ...]

  partner   Partner  @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  @@unique([partnerId, year, month, week])
  @@index([partnerId, year, month])
  @@index([riskScore])
  @@index([week]) // 주간 조회 최적화
  @@map("PartnerPerformance")
}

// Menu #57: PartnerRiskFlags Model (위험 신호 추적)
model PartnerRiskFlags {
  id        String @id @default(cuid())
