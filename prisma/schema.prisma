generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── 테넌트 (파트너 회사 단위) ───────────────────────────────────
model Organization {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  plan         String   @default("FREE")
  externalAffiliateProfileId Int? @unique

  members       OrganizationMember[]
  contacts      Contact[]
  contactGroups ContactGroup[]
  landingPages  CrmLandingPage[]
  funnels       Funnel[]
  smsTemplates     SmsTemplate[]
  smsConfig        OrgSmsConfig?
  emailConfig      OrgEmailConfig?
  scheduledSmsList ScheduledSms[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ─── 조직별 Aligo SMS 설정 ────────────────────────────────────
model OrgSmsConfig {
  id             String       @id @default(cuid())
  organizationId String       @unique
  aligoKey       String       // Aligo API Key
  aligoUserId    String       // Aligo User ID
  senderPhone      String        // 발신번호 (등록된 번호)
  isActive         Boolean       @default(true)
  senderVerified   Boolean       @default(false)  // Aligo 발신번호 인증 여부
  verifiedAt       DateTime?                       // 인증 완료 시각
  arsNum           String?                         // 진행 중인 ARS 인증번호 (임시)
  organization     Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  updatedAt        DateTime      @updatedAt
}

// ─── 조직별 이메일 설정 ────────────────────────────────────────
model OrgEmailConfig {
  id             String       @id @default(cuid())
  organizationId String       @unique
  senderName     String       // 발신자 이름
  senderEmail    String       // 발신 이메일
  smtpHost       String       // SMTP 호스트 (smtp.gmail.com 등)
  smtpPort       Int          @default(587)
  smtpUser       String       // SMTP 계정
  smtpPassEncrypted String    // 암호화된 비밀번호
  isActive       Boolean      @default(true)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  updatedAt      DateTime     @updatedAt
}

model OrganizationMember {
  id             String       @id @default(cuid())
  organizationId String
  userId         String       // Clerk user ID
  // OWNER=대리점장 | AGENT=정식판매원(330만계약) | VIEWER=조회만
  role           String       @default("AGENT")
  displayName    String?      // 이름
  isActive       Boolean      @default(true)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
}

// ─── 글로벌 관리자 (모든 조직 DB 접근 + 삭제 권한) ────────────
model GlobalAdmin {
  id        String   @id @default(cuid())
  userId    String   @unique  // Clerk user ID
  createdAt DateTime @default(now())
}

// ─── 고객 ────────────────────────────────────────────────────
model Contact {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  phone          String
  email          String?
  type           String   @default("LEAD")
  cruiseInterest String?
  budgetRange    String?
  utmSource      String?
  lastContactedAt DateTime?
  purchasedAt    DateTime?
  optOutAt       DateTime?
  adminMemo      String?

  // 리드 스코어링 (WO-25B)
  leadScore      Int       @default(0)   // HOT 70+ / WARM 30~69 / COLD 0~29 / LOST <0

  // 담당 판매원 (AGENT에게 배당된 고객)
  assignedUserId String?   // Clerk userId of the assigned AGENT
  // 크루즈 출발 정보 (VIP 케어 D-day 기준)
  departureDate  DateTime? // 출발 예정일 → D-150, D-90... 자동 계산
  productName    String?   // 상품명 (예: 지중해 7박 MSC)
  bookingRef     String?   // 예약 번호 (PNR 등)

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  groups         ContactGroupMember[]
  callLogs       CallLog[]
  memos          ContactMemo[]
  vipSequences   VipCareSequence[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([phone, organizationId])
  @@index([organizationId])
  @@index([type])
  @@index([assignedUserId])
}

// ─── 고객 그룹 ────────────────────────────────────────────────
model ContactGroup {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  description    String?
  color          String?  @default("#6B7280")
  // 이 그룹에 배정되면 자동으로 시작할 퍼널
  funnelId       String?

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  members        ContactGroupMember[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId])
}

model ContactGroupMember {
  id        String       @id @default(cuid())
  groupId   String
  contactId String
  group     ContactGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  contact   Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)
  addedAt   DateTime     @default(now())

  @@unique([groupId, contactId])
}

// ─── 콜 기록 ────────────────────────────────────────────────
model CallLog {
  id             String   @id @default(cuid())
  contactId      String
  userId         String
  content        String?
  result         String?
  duration       Int?
  convictionScore Int?
  nextAction     String?
  scheduledAt    DateTime?
  contact        Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)

  createdAt      DateTime @default(now())

  @@index([contactId])
  @@index([userId])
}

// ─── 고객 메모 ────────────────────────────────────────────────
model ContactMemo {
  id        String   @id @default(cuid())
  contactId String
  userId    String
  content   String
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([contactId])
}

// ─── 랜딩페이지 ──────────────────────────────────────────────
model CrmLandingPage {
  id             String   @id @default(cuid())
  organizationId String
  title          String
  slug           String
  htmlContent    String?  @db.Text
  isActive       Boolean  @default(true)
  isPublic       Boolean  @default(true)
  viewCount      Int      @default(0)
  autoFunnelId   String?

  // 신청자를 자동으로 배정할 그룹
  groupId        String?

  commentEnabled Boolean  @default(false)  // 방문자 댓글 허용 여부

  organization   Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  registrations  CrmLandingRegistration[]
  comments       CrmLandingComment[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([slug, organizationId])
  @@index([organizationId])
  @@map("CrmLandingPage")
}

// ─── 랜딩페이지 방문자 댓글 ───────────────────────────────────
model CrmLandingComment {
  id              String         @id @default(cuid())
  landingPageId   String
  authorName      String         // 작성자 이름 (비회원)
  content         String         @db.Text
  passwordHash    String?        // bcrypt 해시 (본인 삭제용)
  isAutoGenerated Boolean        @default(false)  // AI 생성 여부
  landingPage     CrmLandingPage @relation(fields: [landingPageId], references: [id], onDelete: Cascade)
  createdAt       DateTime       @default(now())

  @@index([landingPageId])
  @@map("CrmLandingComment")
}

model CrmLandingRegistration {
  id            String         @id @default(cuid())
  landingPageId String
  name          String
  phone         String
  email         String?
  utmSource     String?
  utmMedium     String?   // utm_medium (예: cpc, social, email)
  utmCampaign   String?   // utm_campaign (예: spring_sale)
  metadata      Json?     // 추가 질문 답변 (여행시기, 인원 등 자유형)
  funnelStarted Boolean   @default(false)  // 퍼널 진입 여부
  landingPage   CrmLandingPage @relation(fields: [landingPageId], references: [id], onDelete: Cascade)
  createdAt     DateTime       @default(now())

  @@unique([landingPageId, phone])  // 중복 등록 방지 (race condition 방어)
  @@index([landingPageId])
  @@index([utmSource, utmMedium])
  @@map("CrmLandingRegistration")
}

// ─── 퍼널 자동화 ──────────────────────────────────────────────
model Funnel {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  description    String?
  isActive       Boolean  @default(true)
  funnelType     String   @default("GENERAL")  // VIP_CARE | REGIONAL | GENERAL
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  stages         FunnelStage[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId])
}

model FunnelStage {
  id             String  @id @default(cuid())
  funnelId       String
  order          Int
  name           String
  triggerType    String  @default("DAYS_AFTER")
  triggerOffset  Int     @default(0)
  channel        String  @default("SMS")
  messageContent String? @db.Text
  linkUrl      String?  // SMS에 삽입할 뉴스 URL (선택)
  funnel         Funnel  @relation(fields: [funnelId], references: [id], onDelete: Cascade)

  @@index([funnelId])
}

// ─── VIP 케어 타임라인 ────────────────────────────────────────
model VipCareSequence {
  id           String   @id @default(cuid())
  contactId    String
  funnelId     String?
  startDate    DateTime
  status       String   @default("ACTIVE")
  currentStage Int      @default(0)
  contact      Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  logs         VipCareLog[]

  createdAt    DateTime @default(now())

  @@index([contactId])
  @@index([status])
}

model VipCareLog {
  id          String          @id @default(cuid())
  sequenceId  String
  stageOrder  Int
  scheduledAt DateTime
  sentAt      DateTime?
  status      String          @default("PENDING")
  content     String?         @db.Text
  sequence    VipCareSequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)

  @@index([sequenceId])
  @@index([scheduledAt])
}

// ─── 문자 템플릿 라이브러리 ────────────────────────────────────
model SmsTemplate {
  id             String   @id @default(cuid())
  organizationId String?
  category       String
  title          String
  content        String   @db.Text
  triggerType    String?
  triggerOffset  Int?
  isSystem       Boolean  @default(false)
  usageCount     Int      @default(0)
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId])
  @@index([category])
}

// ─── 수신거부 ────────────────────────────────────────────────
model SmsOptOut {
  id         String   @id @default(cuid())
  phone      String   @unique
  optedOutAt DateTime @default(now())
  reason     String?
}

// ─── SMS 발송 내역 로그 ───────────────────────────────────────
model SmsLog {
  id             String   @id @default(cuid())
  organizationId String
  contactId      String?
  phone          String   // 앞4자***마스킹 저장 (개인정보 최소화)
  contentPreview String   // 발송 내용 앞 30자
  status         String   @default("SENT")  // SENT | FAILED | BLOCKED
  blockReason    String?  // OPT_OUT | NIGHT_BLOCK
  resultCode     String?  // Aligo 응답 코드
  msgId          String?  // Aligo msg_id (재발송 연동용)
  channel        String   @default("FUNNEL") // FUNNEL | GROUP | MANUAL
  sentAt         DateTime @default(now())

  @@index([organizationId, sentAt])
  @@index([contactId, sentAt])
}

// ─── 세일즈 플레이북 ──────────────────────────────────────────
model SalesPlaybook {
  id        String   @id @default(cuid())
  type      String
  title     String
  content   String   @db.Text
  priority  Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
}

// ─── 이미지 캐시 (크루즈닷몰 공유 테이블, 읽기 전용) ─────────────
model ImageCache {
  id           Int      @id @default(autoincrement())
  driveFileId  String   @unique
  path         String
  fileName     String
  folder       String
  title        String
  tags         String[]
  mimeType     String?
  fileSize     Int?
  driveUrl     String?
  thumbnailUrl String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  syncedAt     DateTime @default(now())

  @@index([folder])
  @@index([title])
  @@index([syncedAt])
}

// ─── 콜 녹음 자동저장 + AI 피드백 ───────────────────────────────
model CallRecording {
  id             String   @id @default(cuid())
  callLogId      String?  // 연결된 콜기록 (선택)
  contactId      String
  userId         String
  fileName       String
  fileUrl        String?  // 업로드된 파일 URL
  durationSec    Int?
  transcriptText String?  @db.Text  // 녹음 텍스트 변환본
  aiFeedback     String?  @db.Text  // Claude AI 피드백
  aiScore        Int?     // 0-100 점수

  createdAt      DateTime @default(now())

  @@index([contactId])
  @@index([userId])
}

// ─── 랜딩페이지 조회 중복 방지 (IP 해시 기반 24h dedup) ─────────────
model CrmLandingView {
  id            String   @id @default(cuid())
  landingPageId String
  ipHash        String   // SHA-256(IP + LANDING_VIEW_SALT) — raw IP 저장 금지
  viewedAt      DateTime @default(now())

  @@unique([landingPageId, ipHash])
  @@index([viewedAt])
  @@map("CrmLandingView")
}

// ─── PayApp 결제 ──────────────────────────────────────────────
model PayAppPayment {
  id            String    @id @default(cuid())
  orderId       String    @unique
  amount        Int
  customerName  String
  customerPhone String
  status        String    @default("pending")
  landingPageId String?
  paidAt        DateTime?
  createdAt     DateTime  @default(now())

  @@index([customerPhone])
  @@index([landingPageId])
}

// ─── 예약 발송 (WO-23) ────────────────────────────────────────
model ScheduledSms {
  id             String    @id @default(cuid())
  organizationId String
  contactId      String?   // 개별 발송 대상 (null이면 groupId 기준)
  groupId        String?   // 그룹 발송 대상
  message        String    @db.Text
  scheduledAt    DateTime  // 발송 예정 시각 (KST 기준 UTC 저장)
  status         String    @default("PENDING")  // PENDING | SENT | FAILED | CANCELLED
  sentAt         DateTime?
  sentCount      Int       @default(0)
  failedCount    Int       @default(0)
  createdByUserId String?

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([organizationId, status, scheduledAt])
  @@index([scheduledAt, status])
  @@map("ScheduledSms")
}
