generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── 테넌트 (파트너 회사 단위) ───────────────────────────────────
model Organization {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  plan         String   @default("FREE")
  status       String   @default("ACTIVE")  // ACTIVE | SUSPENDED | TERMINATED
  contractRef  String?  @unique             // GMcruise 계약 참조 ID (webhook idempotency)
  externalAffiliateProfileId Int? @unique

  members         OrganizationMember[]
  contacts        Contact[]
  documents       Document[]
  contactGroups ContactGroup[]
  landingPages  CrmLandingPage[]
  funnels       Funnel[]
  smsTemplates     SmsTemplate[]
  smsConfig        OrgSmsConfig?
  emailConfig      OrgEmailConfig?
  scheduledSmsList  ScheduledSms[]
  inviteTokens      OrgInviteToken[]
  sentTransfers     ContactTransferLog[] @relation("FromOrg")
  receivedTransfers ContactTransferLog[] @relation("ToOrg")
  affiliateSales    AffiliateSale[]
  b2bProspects      B2BProspect[]
  aiCallLogs        AiCallLog[]
  scriptPatterns    ScriptPattern[]
  shortLinks        ShortLink[]
  salesDocuments    SalesDocument[]
  salesDocApprovals SalesDocumentApproval[]
  memberDocuments   MemberDocument[]
  goldMembers       GoldMember[]
  adminMessages     AdminMessage[]
  partners          Partner[]
  imageAssets       ImageAsset[]
  importLogs        ImportLog[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ─── 조직별 Aligo SMS 설정 ────────────────────────────────────
model OrgSmsConfig {
  id             String       @id @default(cuid())
  organizationId String       @unique
  aligoKey       String       // Aligo API Key
  aligoUserId    String       // Aligo User ID
  senderPhone      String        // 발신번호 (등록된 번호)
  isActive         Boolean       @default(true)
  senderVerified   Boolean       @default(false)  // Aligo 발신번호 인증 여부
  verifiedAt       DateTime?                       // 인증 완료 시각
  arsNum           String?                         // 진행 중인 ARS 인증번호 (임시)
  // 재진입 메시지 커스터마이즈 (WO-26) — null이면 시스템 기본 메시지 사용
  reEngageMsg1     String?       @db.Text          // 1차 재진입 메시지
  reEngageMsg2     String?       @db.Text          // 2차 재진입 메시지
  organization     Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  updatedAt        DateTime      @updatedAt
}

// ─── 조직별 이메일 설정 ────────────────────────────────────────
model OrgEmailConfig {
  id             String       @id @default(cuid())
  organizationId String       @unique
  senderName     String       // 발신자 이름
  senderEmail    String       // 발신 이메일
  smtpHost       String       // SMTP 호스트 (smtp.gmail.com 등)
  smtpPort       Int          @default(587)
  smtpUser       String       // SMTP 계정
  smtpPassEncrypted String    // 암호화된 비밀번호
  isActive       Boolean      @default(true)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  updatedAt      DateTime     @updatedAt
}

model OrganizationMember {
  id             String       @id @default(cuid())
  organizationId String
  userId         String       // Clerk 제거 후: memberId 자체 또는 GMcruise User.id
  // OWNER=대리점장 | AGENT=정식판매원(330만계약) | FREE_SALES=프리세일즈
  role           String       @default("AGENT")
  displayName    String?      // 이름
  isActive       Boolean      @default(true)
  phone          String?      // 로그인용 전화번호 (예: 01012345678)
  email          String?      // 알림 수신용 이메일 (OWNER 가입 완료 알림 발송 대상)
  passwordHash   String?      // bcrypt 해시 (SHA-256 사용 금지)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
}

// ─── 글로벌 관리자 (모든 조직 DB 접근 + 삭제 권한) ────────────
model GlobalAdmin {
  id           String   @id @default(cuid())
  userId       String?  @unique  // Clerk 제거 후 선택적
  phone        String?  @unique
  passwordHash String?
  displayName  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
// ─── Mabiz 세션 (Clerk 제거 후 세션 쿠키 기반 인증) ─────────────
model MabizSession {
  id             String   @id @default(cuid())
  memberId       String?  // OrganizationMember.id
  adminId        String?  // GlobalAdmin.id
  mallUserId     Int?     // GMcruise User.id (크루즈닷몰 공유 계정)
  role           String   // GLOBAL_ADMIN | OWNER | AGENT | FREE_SALES
  organizationId String?
  expiresAt      DateTime
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([memberId])
  @@index([adminId])
  @@index([mallUserId])
  @@map("MabizSession")
}


// ─── 고객 ────────────────────────────────────────────────────
model Contact {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  phone          String
  email          String?
  type           String   @default("LEAD")
  channel        String   @default("direct")  // b2c(크루즈닷몰), b2b(페이앱), direct(직접등록)
  cruiseInterest String?
  budgetRange    String?
  utmSource      String?
  lastContactedAt DateTime?
  purchasedAt    DateTime?
  optOutAt       DateTime?
  adminMemo      String?

  // 리드 스코어링 (WO-25B)
  leadScore      Int       @default(0)   // HOT 70+ / WARM 30~69 / COLD 0~29 / LOST <0

  // 고객 태그 (WO-25C) — 세그먼트 기반 타겟 발송
  tags           String[]  @default([])  // 예: ["지중해", "가족", "봄출발"]

  // 이탈 감지 + 재진입 (WO-26)
  reEngagedAt    DateTime?              // 마지막 재진입 시도 시각
  reEngageCount  Int       @default(0)  // 재진입 시도 횟수 (최대 2회)

  // 담당 판매원 (AGENT에게 배당된 고객)
  assignedUserId  String?   // Clerk userId of the assigned AGENT

  // 어필리에이트 추적 (WO-28) — 프리세일즈/직속판매원 링크 유입 모두 포함
  affiliateCode   String?   // 크루즈몰 affiliateCode (파트너 고유 코드)
  sourceOrgId     String?   // DB 전달 시 원본 조직 ID (이력 추적)
  // 크루즈 출발 정보 (VIP 케어 D-day 기준)
  departureDate  DateTime? // 출발 예정일 → D-150, D-90... 자동 계산
  productName    String?   // 상품명 (예: 지중해 7박 MSC)
  bookingRef     String?   // 예약 번호 (PNR 등)

  // 파트너 배정 (TASK-016)
  partnerId      String?
  partner        Partner? @relation(fields: [partnerId], references: [id], onDelete: SetNull)

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  groups         ContactGroupMember[]
  callLogs       CallLog[]
  memos          ContactMemo[]
  vipSequences   VipCareSequence[]
  shortLinks     ShortLink[]
  shortLinkClicks ShortLinkClick[]
  salesDocuments  SalesDocument[]
  documents       Document[]
  funnelState    ContactFunnelState?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  deletedAt      DateTime?               // 소프트 삭제 일시 (null = 활성)

  @@unique([phone, organizationId])
  @@index([organizationId])
  @@index([type])
  @@index([assignedUserId])
  @@index([partnerId])
  @@index([deletedAt])
}

// ─── 고객 그룹 ────────────────────────────────────────────────
model ContactGroup {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  description    String?
  color          String?  @default("#6B7280")
  // 이 그룹에 배정되면 자동으로 시작할 퍼널
  funnelId       String?
  // 그룹 소유자 (OrganizationMember.id 또는 GlobalAdmin.id)
  // null = 조직 공유 그룹 (기존 데이터 호환), 있으면 개인 그룹
  ownerId        String?

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  members        ContactGroupMember[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId])
  @@index([ownerId])
}

model ContactGroupMember {
  id        String       @id @default(cuid())
  groupId   String
  contactId String
  group     ContactGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  contact   Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)
  addedAt   DateTime     @default(now())

  @@unique([groupId, contactId])
}

// ─── 콜 기록 ────────────────────────────────────────────────
model CallLog {
  id             String   @id @default(cuid())
  contactId      String
  userId         String
  content        String?
  result         String?
  duration       Int?
  convictionScore Int?
  nextAction     String?
  scheduledAt    DateTime?
  contact        Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)

  createdAt      DateTime @default(now())

  @@index([contactId])
  @@index([userId])
  @@index([contactId, createdAt(sort: Desc)])  // ✅ 페이지네이션 빠르게 조회
}

// ─── 고객 메모 ────────────────────────────────────────────────
model ContactMemo {
  id        String   @id @default(cuid())
  contactId String
  userId    String
  content   String
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([contactId])
}

// ─── 랜딩페이지 ──────────────────────────────────────────────
model CrmLandingPage {
  id             String   @id @default(cuid())
  organizationId String
  title          String
  slug           String
  htmlContent    String?  @db.Text
  isActive       Boolean  @default(true)
  isPublic       Boolean  @default(true)
  viewCount      Int      @default(0)
  autoFunnelId   String?

  // 신청자를 자동으로 배정할 그룹
  groupId        String?

  commentEnabled Boolean  @default(false)  // 방문자 댓글 허용 여부

  // 결제 설정 (페이앱 B2B)
  paymentEnabled Boolean  @default(false)
  paymentType    String?  // "onetime" | "subscription"
  productName    String?
  productPrice   Int?
  cycleDay       Int?     // 정기결제 매월 결제일 (1~31, 90=말일)
  expireDate     DateTime? // 정기결제 만료일

  organization   Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  registrations  CrmLandingRegistration[]
  comments       CrmLandingComment[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([slug, organizationId])
  @@index([organizationId])
  @@map("CrmLandingPage")
}

// ─── 랜딩페이지 방문자 댓글 ───────────────────────────────────
model CrmLandingComment {
  id              String         @id @default(cuid())
  landingPageId   String
  authorName      String         // 작성자 이름 (비회원)
  content         String         @db.Text
  passwordHash    String?        // bcrypt 해시 (본인 삭제용)
  isAutoGenerated Boolean        @default(false)  // AI 생성 여부
  landingPage     CrmLandingPage @relation(fields: [landingPageId], references: [id], onDelete: Cascade)
  createdAt       DateTime       @default(now())

  @@index([landingPageId])
  @@map("CrmLandingComment")
}

model CrmLandingRegistration {
  id            String         @id @default(cuid())
  landingPageId String
  name          String
  phone         String
  email         String?
  utmSource     String?
  utmMedium     String?   // utm_medium (예: cpc, social, email)
  utmCampaign   String?   // utm_campaign (예: spring_sale)
  metadata      Json?     // 추가 질문 답변 (여행시기, 인원 등 자유형)
  funnelStarted Boolean   @default(false)  // 퍼널 진입 여부
  landingPage   CrmLandingPage @relation(fields: [landingPageId], references: [id], onDelete: Cascade)
  createdAt     DateTime       @default(now())

  @@unique([landingPageId, phone])  // 중복 등록 방지 (race condition 방어)
  @@index([landingPageId])
  @@index([utmSource, utmMedium])
  @@map("CrmLandingRegistration")
}

// ─── 퍼널 자동화 ──────────────────────────────────────────────
model Funnel {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  description    String?
  isActive       Boolean  @default(true)
  funnelType     String   @default("GENERAL")  // VIP_CARE | REGIONAL | GENERAL
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  stages         FunnelStage[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId])
}

model FunnelStage {
  id             String  @id @default(cuid())
  funnelId       String
  order          Int
  name           String
  triggerType    String  @default("DAYS_AFTER")
  triggerOffset  Int     @default(0)
  channel        String  @default("SMS")
  messageContent String? @db.Text
  linkUrl      String?  // SMS에 삽입할 뉴스 URL (선택)
  funnel         Funnel  @relation(fields: [funnelId], references: [id], onDelete: Cascade)

  @@index([funnelId])
  @@map("CrmFunnelStage")
}

// ─── VIP 케어 타임라인 ────────────────────────────────────────
model VipCareSequence {
  id           String   @id @default(cuid())
  contactId    String
  funnelId     String?
  startDate    DateTime
  status       String   @default("ACTIVE")
  currentStage Int      @default(0)
  contact      Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  logs         VipCareLog[]

  createdAt    DateTime @default(now())

  @@index([contactId])
  @@index([status])
}

model VipCareLog {
  id          String          @id @default(cuid())
  sequenceId  String
  stageOrder  Int
  scheduledAt DateTime
  sentAt      DateTime?
  status      String          @default("PENDING")
  content     String?         @db.Text
  sequence    VipCareSequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)

  @@index([sequenceId])
  @@index([scheduledAt])
}

// ─── 문자 템플릿 라이브러리 ────────────────────────────────────
model SmsTemplate {
  id             String   @id @default(cuid())
  organizationId String?
  category       String
  title          String
  content        String   @db.Text
  triggerType    String?
  triggerOffset  Int?
  isSystem       Boolean  @default(false)
  usageCount     Int      @default(0)
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId])
  @@index([category])
}

// ─── 수신거부 ────────────────────────────────────────────────
model SmsOptOut {
  id         String   @id @default(cuid())
  phone      String   @unique
  optedOutAt DateTime @default(now())
  reason     String?
}

// ─── SMS 발송 내역 로그 ───────────────────────────────────────
model SmsLog {
  id             String   @id @default(cuid())
  organizationId String
  contactId      String?
  phone          String   // 앞4자***마스킹 저장 (개인정보 최소화)
  contentPreview String   // 발송 내용 앞 30자
  status         String   @default("SENT")  // SENT | FAILED | BLOCKED
  blockReason    String?  // OPT_OUT | NIGHT_BLOCK
  resultCode     String?  // Aligo 응답 코드
  msgId          String?  // Aligo msg_id (재발송 연동용)
  channel        String   @default("FUNNEL") // FUNNEL | GROUP | MANUAL
  sentAt         DateTime @default(now())

  @@index([organizationId, sentAt])
  @@index([contactId, sentAt])
  @@map("CrmSmsLog")
}

// ─── 세일즈 플레이북 ──────────────────────────────────────────
model SalesPlaybook {
  id        String   @id @default(cuid())
  type      String
  title     String
  content   String   @db.Text
  priority     Int      @default(0)
  isActive     Boolean  @default(true)
  scriptTab    String   @default("GENERAL")
  productCode  String   @default("ALL")
  sectionOrder Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([type])
}

// ─── 이미지 캐시 (크루즈닷몰 공유 테이블, 읽기 전용) ─────────────
model ImageCache {
  id           Int      @id @default(autoincrement())
  driveFileId  String   @unique
  path         String
  fileName     String
  folder       String
  title        String
  tags         String[]
  mimeType     String?
  fileSize     Int?
  driveUrl     String?
  thumbnailUrl String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  syncedAt     DateTime @default(now())

  @@index([folder])
  @@index([title])
  @@index([syncedAt])
}

// ─── 콜 녹음 자동저장 + AI 피드백 ───────────────────────────────
model CallRecording {
  id             String   @id @default(cuid())
  callLogId      String?  // 연결된 콜기록 (선택)
  contactId      String
  userId         String
  fileName       String
  fileUrl        String?  // 업로드된 파일 URL
  durationSec    Int?
  transcriptText String?  @db.Text  // 녹음 텍스트 변환본
  aiFeedback     String?  @db.Text  // Claude AI 피드백
  aiScore        Int?     // 0-100 점수

  createdAt      DateTime @default(now())

  @@index([contactId])
  @@index([userId])
}

// ─── 랜딩페이지 조회 중복 방지 (IP 해시 기반 24h dedup) ─────────────
model CrmLandingView {
  id            String   @id @default(cuid())
  landingPageId String
  ipHash        String   // SHA-256(IP + LANDING_VIEW_SALT) — raw IP 저장 금지
  viewedAt      DateTime @default(now())

  @@unique([landingPageId, ipHash])
  @@index([viewedAt])
  @@map("CrmLandingView")
}

// ─── PayApp 결제 (B2B 전용 — 크루즈닷몰 공유 테이블 아님) ─────
model PayAppPayment {
  id            String    @id @default(cuid())
  orderId       String    @unique
  amount        Int
  customerName  String
  customerPhone String
  status        String    @default("pending") // pending/paid/refunded/partial_refunded/cancelled
  landingPageId String?
  paidAt        DateTime?
  createdAt     DateTime  @default(now())

  // 조직 (테넌트 격리)
  organizationId String?

  // 결제 상세
  productName   String?
  customerEmail String?
  mulNo         String?   // PayApp 결제요청번호
  payType       String?   // 1=카드,2=휴대폰,6=계좌이체,7=가상계좌,15=카카오페이 등
  cardName      String?   // 결제 카드명
  cstUrl        String?   // 매출전표 URL

  // 환불
  refundedAt    DateTime?
  refundAmount  Int       @default(0)
  refundReason  String?

  // 메타데이터 (부분환불 이력, 현금영수증 정보 등)
  metadata      Json?

  // 정기결제 연결
  subscriptionId String?
  subscription   PayAppSubscription? @relation(fields: [subscriptionId], references: [id])

  @@index([customerPhone])
  @@index([landingPageId])
  @@index([mulNo])
  @@index([status])
  @@map("CrmPayAppPayment")
}

// ─── PayApp 정기결제 (B2B 전용) ──────────────────────────────────
model PayAppSubscription {
  id              String    @id @default(cuid())
  organizationId  String
  rebillNo        String    @unique   // PayApp 정기결제 등록번호
  goodname        String              // 상품명
  goodprice       Int                 // 정기결제 금액
  customerName    String
  customerPhone   String
  customerEmail   String?
  cycleDay        Int       @default(1)   // 매월 결제일 (1~31, 90=말일)
  expireDate      DateTime              // 만료일
  status          String    @default("pending") // pending/active/paused/cancelled
  payUrl          String?               // 최초 결제 URL
  landingPageId   String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  payments        PayAppPayment[]

  @@index([organizationId])
  @@index([status])
  @@map("CrmPayAppSubscription")
}

// ─── 예약 발송 (WO-23) ────────────────────────────────────────
model ScheduledSms {
  id             String    @id @default(cuid())
  organizationId String
  contactId      String?   // 개별 발송 대상 (null이면 groupId 기준)
  groupId        String?   // 그룹 발송 대상
  message        String    @db.Text
  scheduledAt    DateTime  // 발송 예정 시각 (KST 기준 UTC 저장)
  status         String    @default("PENDING")  // PENDING | SENT | FAILED | CANCELLED
  sentAt         DateTime?
  sentCount      Int       @default(0)
  failedCount    Int       @default(0)
  createdByUserId String?

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([organizationId, status, scheduledAt])
  @@index([scheduledAt, status])
  @@map("ScheduledSms")
}

// ─── 판매원 초대 토큰 (WO-27B) ───────────────────────────────
model OrgInviteToken {
  id             String    @id @default(cuid())
  organizationId String
  token          String    @unique  // randomBytes(32).toString('base64url') — API에서 생성, cuid() 사용 금지
  role           String    @default("AGENT")
  note           String?   // 초대 메모 (예: "홍길동 판매원")
  expiresAt      DateTime  // 만료 시각 (기본 14일)
  usedAt         DateTime?
  usedByUserId   String?   // OrganizationMember.id (가입 완료한 멤버)
  // 수당 조건 동의 기록
  agreedToTerms  Boolean   @default(false)
  createdByUserId String?

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt      DateTime  @default(now())

  @@index([organizationId])
  @@index([expiresAt])
  @@map("OrgInviteToken")
}

// ─── DB 전달 이력 (WO-28) ─────────────────────────────────────
model ContactTransferLog {
  id             String    @id @default(cuid())
  contactId      String    // 전달된 contact (원본)
  fromOrgId      String    // 보낸 조직
  toOrgId        String?   // 받은 조직 (ORG_COPY 모드)
  toUserId       String?   // 받은 판매원 userId (AGENT_ASSIGN 모드)
  newContactId   String?   // 복사 후 새로 생성된 contact ID
  transferType   String    // "ORG_COPY" | "AGENT_ASSIGN"
  transferredBy  String    // 전달한 사람 Clerk userId
  note           String?   // 전달 메모

  fromOrg        Organization @relation("FromOrg", fields: [fromOrgId], references: [id], onDelete: Cascade)
  toOrg          Organization? @relation("ToOrg",  fields: [toOrgId],   references: [id], onDelete: SetNull)

  createdAt      DateTime  @default(now())

  @@index([contactId])
  @@index([fromOrgId])
  @@index([toOrgId])
  @@index([transferredBy])
  @@map("ContactTransferLog")
}

// ─── 어필리에이트 판매 이력 (WO-28B) ─────────────────────────
// 크루즈몰 결제 완료 → 웹훅 → mabiz에 저장
model AffiliateSale {
  id              String    @id @default(cuid())
  organizationId  String    // 소속 조직 (대리점)
  affiliateCode   String    // 판매한 파트너 어필리에이트 코드
  affiliateUserId String?   // mabiz Clerk userId (연결된 경우)
  productName     String    // 상품명
  saleAmount      Int       // 판매 금액 (원)
  commissionRate  Int       @default(0)  // 수당률 % (예: 5)
  commissionAmount Int      @default(0)  // 예상 수당 (원)
  status          String    @default("PENDING")
  // PENDING=출발전 | EARNED=여행완료=지급확정 | PAID=지급완료 | CANCELLED=취소
  travelCompletedAt DateTime? // 여행 완료 확인 시각
  paidAt          DateTime?   // 실제 지급 시각
  customerPhone   String?     // 마스킹 저장 (앞4자리만)
  orderId         String?     @unique  // 크루즈몰 주문번호
  sourceWebhook   String?     // 웹훅 출처 (purchase/payapp)

  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  salesDocuments  SalesDocument[]

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([organizationId])
  @@index([affiliateCode])
  @@index([affiliateUserId])
  @@index([status])
  @@map("CrmAffiliateSale")
}

// ─── B2B 잠재고객 (WO-28C) ───────────────────────────────────
// 330만/540만/750만 패키지 구매 가능성 있는 잠재고객 파이프라인
model B2BProspect {
  id              String    @id @default(cuid())
  organizationId  String
  name            String    // 담당자 이름
  phone           String    // 전화번호
  email           String?
  companyName     String?   // 회사명 (단체/기업 대상)
  position        String?   // 직책
  groupSize       Int?      // 예상 인원
  packageInterest String?   // "330" | "540" | "750" | null
  budget          String?   // 예산 범위 메모
  preferredDate   String?   // 희망 시기
  destination     String?   // 희망 목적지
  status          String    @default("NEW")
  // NEW=신규 | CONTACTED=연락함 | NEGOTIATING=협상중 | WON=계약성사 | LOST=실패
  notes           String?   @db.Text
  assignedUserId  String?   // 담당 판매원
  source          String?   // 유입 경로 (B2B_LANDING, DIRECT, REFERRAL 등)
  affiliateCode   String?   // 유입시킨 파트너 코드

  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([organizationId, status])
  @@index([assignedUserId])
  @@index([affiliateCode])
  @@map("CrmB2BProspect")
}

model AiCallLog {
  id             String          @id @default(cuid())
  organizationId String
  agentUserId    String
  productType    String          // GOLD | GENERAL
  personaType    String?
  rawTextMasked  String          @db.Text
  converted      Boolean         @default(false)
  durationSec    Int?
  analysisStatus String          @default("PENDING")
  productCode    String          @default("ALL")
  uploadedAt     DateTime        @default(now())
  organization   Organization    @relation(fields: [organizationId], references: [id])
  analysis       AiCallAnalysis?
  @@map("AiCallLog")
}

model AiCallAnalysis {
  id                String     @id @default(cuid())
  callLogId         String     @unique
  callLog           AiCallLog  @relation(fields: [callLogId], references: [id], onDelete: Cascade)
  personaDetected   String
  personaConfidence Float      @default(0)
  scores            Json
  keyPhrases        Json
  strengths         Json
  weaknesses        Json
  objectionTypes    Json
  goldValueScore    Float?
  analyzedAt        DateTime   @default(now())
  @@map("AiCallAnalysis")
}

model ScriptPattern {
  id             String       @id @default(cuid())
  organizationId String
  productType    String
  personaType    String
  category       String
  objectionType  String?
  patternText    String       @db.Text
  exampleCall    String?      @db.Text
  useCount       Int          @default(0)
  conversionRate Float        @default(0)
  productCode    String       @default("ALL")
  status         String       @default("DRAFT")
  approvedBy     String?
  approvedAt     DateTime?
  extractedAt    DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id])
  @@map("ScriptPattern")
}

// ─── 숏링크 ──────────────────────────────────────────────────
model ShortLink {
  id             String           @id @default(cuid())
  organizationId String
  code           String           @unique
  targetUrl      String
  title          String?
  contactId      String?
  category       String?
  autoGroupId    String?
  clickCount     Int              @default(0)
  isActive       Boolean          @default(true)
  createdAt      DateTime         @default(now())
  organization   Organization     @relation(fields: [organizationId], references: [id])
  contact        Contact?         @relation(fields: [contactId], references: [id])
  clicks         ShortLinkClick[]
  @@map("ShortLink")
}

model ShortLinkClick {
  id          String    @id @default(cuid())
  linkId      String
  contactId   String?
  clickedAt   DateTime  @default(now())
  userAgent   String?
  link        ShortLink @relation(fields: [linkId], references: [id], onDelete: Cascade)
  contact     Contact?  @relation(fields: [contactId], references: [id])
  @@map("ShortLinkClick")
}

model NewsShortLink {
  id             String   @id @default(cuid())
  organizationId String?  // null = 전체 공용
  shortCode      String   @unique
  title          String
  url            String
  isActive       Boolean  @default(true)
  syncedAt       DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  @@map("NewsShortLink")
}

model NewsSyncState {
  id           String   @id @default("global")
  lastSyncedAt DateTime @default(now())
  @@map("NewsSyncState")
}

// ─── 크루즈닷 결제 데이터 (동일 Neon DB 공유) ────────────────
// 마이그레이션 불필요 — 크루즈닷과 동일 테이블을 읽기 전용으로 참조
model Payment {
  id              Int       @id @default(autoincrement())
  orderId         String    @unique
  buyerName       String
  buyerTel        String
  buyerEmail      String?
  amount          Int
  status          String    @default("pending")
  pgProvider      String?
  pgTransactionId String?
  paidAt          DateTime?
  cancelledAt     DateTime?
  productName     String?
  affiliateCode   String?
  metadata        Json?
  @@map("Payment")
}

// ─── 영업 문서 (견적서·구매확인서·환불증명서) ─────────────────
model SalesDocument {
  id              String   @id @default(cuid())
  organizationId  String
  documentType    String
  // COMPARISON_QUOTE | PURCHASE_CONFIRMATION | REFUND_CERTIFICATE
  status          String   @default("DRAFT")
  // DRAFT | PENDING_APPROVAL | APPROVED | REJECTED
  orderId         String?
  affiliateSaleId String?
  contactId       String?
  generatedData   Json
  filePath        String?
  approvedBy      String?
  approvedAt      DateTime?
  rejectedReason  String?
  createdBy       String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization    Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contact         Contact?      @relation(fields: [contactId], references: [id])
  affiliateSale   AffiliateSale? @relation(fields: [affiliateSaleId], references: [id])
  approvals       SalesDocumentApproval[]

  @@index([organizationId, documentType])
  @@index([organizationId, status])
  @@index([orderId])
  @@map("SalesDocument")
}

model SalesDocumentApproval {
  id             String    @id @default(cuid())
  documentId     String
  organizationId String
  requestedBy    String
  approvedBy     String?
  status         String    @default("PENDING")
  requestNote    String?   @db.Text
  adminNote      String?   @db.Text
  processedAt    DateTime?

  document       SalesDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([organizationId, status])
  @@index([documentId])
  @@map("SalesDocumentApproval")
}

// ─── 인력 서류 관리 ─────────────────────────────────────────────
model MemberDocument {
  id             String   @id @default(cuid())
  organizationId String
  userId         String   // Clerk user ID (OrganizationMember.userId)
  docType        String   // ID_CARD | BANK_ACCOUNT | CONTRACT | OTHER
  fileName       String
  fileUrl        String   // Supabase Storage URL
  storagePath    String   // Supabase 내부 경로
  fileSize       Int?     // bytes
  status         String   @default("UPLOADED") // UPLOADED | APPROVED | REJECTED
  note           String?  // 관리자 메모
  uploadedAt     DateTime @default(now())
  approvedAt     DateTime?

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([userId])
  @@index([organizationId, userId])
  @@map("MemberDocument")
}

// ─── 골드회원 ────────────────────────────────────────────────
model GoldMember {
  id             String   @id @default(cuid())
  organizationId String

  // 기본 정보
  name           String
  phone          String
  email          String?
  memberCode     String   @unique   // 골드 업그레이드 코드 (6자리 대문자)

  // 코스 정보
  courseType     String   // A | B | C

  // 가입/납부 정보
  joinDate       DateTime
  paymentDay     Int?               // 매월 납부 예정일 (1~31)
  totalPayments  Int      @default(0)  // 총 납부 예정 횟수
  paidCount      Int      @default(0)  // 현재까지 납부 횟수

  // 상태
  status         String   @default("ACTIVE")  // ACTIVE | SUSPENDED | CANCELLED

  // 메모
  memo           String?  @db.Text

  organization   Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  consultations  GoldMemberConsultation[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId])
  @@index([memberCode])
}

model GoldMemberConsultation {
  id           String     @id @default(cuid())
  goldMemberId String
  content      String     @db.Text
  authorId     String     // CRM 담당자 ID (getMabizSession의 userId)
  createdAt    DateTime   @default(now())

  goldMember   GoldMember @relation(fields: [goldMemberId], references: [id], onDelete: Cascade)

  @@index([goldMemberId])
}

// ─── 시스템 설정 (크루즈몰 공유 테이블) ─────────────────────────
// 계약서 템플릿 등 시스템 설정 저장용 — 크루즈몰과 동일 Neon DB 공유
model SystemConfig {
  id          Int      @id @default(autoincrement())
  configKey   String   @unique
  configValue String?
  description String?
  category    String   @default("general")
  isActive    Boolean  @default(true)
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("SystemConfig")
}

// ─── 웹 푸시 구독 정보 ─────────────────────────────────────────
model PushSubscription {
  id        String   @id @default(cuid())
  userId    String   // OrganizationMember.id 또는 GlobalAdmin.id
  endpoint  String   @unique  // 브라우저가 제공하는 고유 엔드포인트
  p256dh    String   // ECDH 공개 키 (base64)
  auth      String   // 인증 토큰 (base64)
  role      String   // OWNER | AGENT | GLOBAL_ADMIN
  createdAt DateTime @default(now())

  @@index([userId])
}

// ─── 사용자별 푸시 설정 ────────────────────────────────────────
model UserPushSettings {
  id            String   @id @default(cuid())
  userId        String   @unique  // OrganizationMember.id 또는 GlobalAdmin.id
  notifyEnabled Boolean  @default(true)  // 푸시 알림 활성화 여부
  notifyAtHour  Int      @default(9)     // 0-23: 몇 시에 자동 푸시할지
  lastPushedAt  DateTime?                 // 마지막으로 푸시 발송한 날짜+시간
  updatedAt     DateTime @updatedAt
}

// ─── DLQ: Webhook 실패 재시도 큐 ─────────────────────────────
model MabizSyncDLQ {
  id             String    @id @default(cuid())
  webhookType    String    // purchase | refund | inquiry | gold-inquiry | partner-signup | news-sync | cruise-purchase | payapp
  payload        Json      // 원본 webhook payload
  failureReason  String    @db.Text
  retryCount     Int       @default(0)
  maxRetries     Int       @default(3)
  nextRetryAt    DateTime?
  resolvedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([resolvedAt, nextRetryAt])
  @@index([webhookType])
  @@map("MabizSyncDLQ")
}

// ─── Google Drive 백업 재시도 큐 ─────────────────────────────
model BackupJob {
  id          String   @id @default(cuid())
  type        String   // 'CALL_LOG' (나중에 다른 타입 추가 가능)
  targetId    String   // contactId
  payload     Json     // { userId, displayName, customerName, customerPhone }
  status      String   @default("PENDING")  // PENDING | SUCCESS | FAILED
  retryCount  Int      @default(0)
  maxRetries  Int      @default(3)
  lastError   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status, createdAt(sort: Desc)])
  @@index([targetId, status])
}

// ─── 관리자 메시지 발송 이력 (SMS/카카오) ─────────────────────
model AdminMessage {
  id               String       @id @default(cuid())
  organizationId   String
  adminId          String       // OrganizationMember.id 또는 GlobalAdmin.id
  messageType      String       // 'sms' | 'kakao'
  content          String       @db.Text
  totalSent        Int          @default(0)
  successCount     Int          @default(0)
  createdAt        DateTime     @default(now())

  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([organizationId, createdAt(sort: Desc)])
}

// ─── 파트너 대시보드 (TASK-016) ──────────────────────────────
model Partner {
  id String @id @default(cuid())
  organizationId String
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  name String
  email String?
  phone String?
  status String @default("ACTIVE")  // ACTIVE/INACTIVE
  commissionRate Decimal? @db.Decimal(5, 2)
  totalRevenue BigInt @default(0)

  contacts Contact[]
  metrics PartnerMetrics[]

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  @@unique([organizationId, name])
  @@index([organizationId])
  @@index([status])
}

model PartnerMetrics {
  id String @id @default(cuid())
  partnerId String
  partner Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  year Int
  month Int
  customerCount Int @default(0)
  leadCount Int @default(0)
  revenue BigInt @default(0)

  createdAt DateTime @default(now()) @db.Timestamptz(6)

  @@unique([partnerId, year, month])
  @@index([partnerId, year, month])
}

// ─── 퍼널 상태 전이 (고객별 상태 관리) ──────────────────────────
model ContactFunnelState {
  id                String    @id @default(cuid())
  organizationId    String
  contactId         String    @unique
  contact           Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)

  status            String    @default("PENDING")  // PENDING|ACTIVE|WAITING|COMPLETED|FAILED|ARCHIVED
  nextScheduledAt   DateTime? @db.Timestamptz(6)
  metadata          Json?     @db.JsonB  // 실패 이유, 커스텀 필드 등

  createdAt         DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime  @updatedAt @db.Timestamptz(6)

  @@index([organizationId, status])
  @@index([nextScheduledAt])
  @@map("ContactFunnelState")
}

// ─── 이미지 자산 (조직별 Google Drive 통합 관리) ─────────────────
model ImageAsset {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Text
  organizationId String

  originalFileName String
  driveFileId String
  drivePath String?

  mimeType String?
  fileSize BigInt?
  width Int?
  height Int?

  tags String[]
  category String?

  uploadedBy String
  uploadedAt DateTime @default(now()) @db.Timestamptz(6)
  lastAccessedAt DateTime? @db.Timestamptz(6)

  // 워터마크+WebP 처리 결과
  webpDriveFileId  String?
  processedAt      DateTime? @db.Timestamptz(6)
  processingStatus String    @default("PENDING") // PENDING|DONE|FAILED

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, driveFileId])
  @@index([organizationId, category])
  @@map("ImageAsset")
}

// ─── Import 이력 (b2b/migrate에서 생성, 고객 일괄 업로드 추적) ──
model ImportLog {
  id             String   @id @default(cuid())
  organizationId String
  target         String   // 대상 (contacts, b2b 등)
  totalRows      Int      @map("total_rows")
  successfulRows Int      @map("successful_rows")
  failedRows     Int      @map("failed_rows")
  errors         String?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())

  @@index([organizationId])
  @@index([target])
  @@index([createdAt])
  @@map("ImportLog")
}

// ─── 푸시 발송 이력 (웹 푸시 알림 발송 기록) ──────────────────
model PushLog {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Text
  organizationId    String
  subscriptionCount Int
  successCount      Int      @default(0)
  failureCount      Int      @default(0)
  createdAt         DateTime @default(now()) @db.Timestamptz(6)

  @@index([organizationId, createdAt(sort: Desc)])
  @@map("PushLog")
}

// ─── Google Calendar OAuth 토큰 (사용자별) ───────────────────
model GoogleCalendarToken {
  id             String   @id @default(cuid())
  userId         String   @unique  // OrganizationMember.userId
  accessToken    String   @db.Text // 암호화 저장
  refreshToken   String   @db.Text // 암호화 저장
  expiresAt      DateTime           // access_token 만료 시각
  calendarEmail  String?            // 연결된 Google 계정 이메일
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("GoogleCalendarToken")
}

// ─── Google Calendar 이벤트 기록 (CRM 전용) ─────────────────────────
// 이벤트 수정/삭제를 위해 Google Event ID를 DB에 저장
model GoogleCalendarEvent {
  id            String   @id @default(cuid())
  userId        String
  googleEventId String   // Google Calendar가 발급한 이벤트 ID
  summary       String
  description   String?
  startTime     DateTime @db.Timestamptz(6)
  endTime       DateTime @db.Timestamptz(6)
  contactId     String?  // 연결된 고객 (선택사항)

  createdAt     DateTime @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime @updatedAt @db.Timestamptz(6)

  @@unique([userId, googleEventId])
  @@index([userId])
  @@index([contactId])
}

// ─── 일반 문서 승인 시스템 (TASK-024) ─────────────────────────
model Document {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Text
  organizationId String
  contactId String?
  contact Contact? @relation(fields: [contactId], references: [id], onDelete: Cascade)

  title String
  description String?
  category String?  // 계약, 영수증, 신원증명, 기타
  status String @default("DRAFT")  // DRAFT|SUBMITTED|APPROVED|REJECTED|ARCHIVED

  driveFileId String?
  fileSize BigInt?
  mimeType String?

  createdBy String
  updatedBy String?

  versions DocumentVersion[]
  approvals DocumentApproval[]

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, title])
  @@index([organizationId, status])
  @@index([organizationId, category])
  @@map("Document")
}

model DocumentVersion {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Text
  documentId String
  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  versionNumber Int
  driveFileId String
  description String?
  uploadedBy String
  uploadedAt DateTime @default(now()) @db.Timestamptz(6)

  @@unique([documentId, versionNumber])
  @@index([documentId, versionNumber(sort: Desc)])
  @@map("DocumentVersion")
}

model DocumentApproval {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Text
  documentId String
  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  approvedBy String
  status String  // APPROVED|REJECTED|PENDING
  comment String?
  createdAt DateTime @default(now()) @db.Timestamptz(6)

  @@unique([documentId, approvedBy])
  @@index([documentId])
  @@map("DocumentApproval")
}

// ═══════════════════════════════════════════════════════════════
// 크루즈닷몰 공유 테이블 (읽기 + 여권/PNR 관리용 쓰기)
// ⚠️ DB 테이블 생성 없음 — 기존 테이블 매핑만
// ⚠️ 스키마 변경 시 크루즈닷몰 팀 협의 필수
// ═══════════════════════════════════════════════════════════════

model GmUser {
  id                          Int       @id @default(autoincrement())
  externalId                  String?
  name                        String?
  email                       String?
  phone                       String?
  password                    String
  onboarded                   Boolean   @default(false)
  loginCount                  Int       @default(0)
  tripCount                   Int       @default(0)
  totalTripCount              Int       @default(0)
  currentTripEndDate          DateTime?
  role                        String    @default("user")
  onboardingUpdatedAt         DateTime?
  lastActiveAt                DateTime?
  hibernatedAt                DateTime?
  isHibernated                Boolean   @default(false)
  isLocked                    Boolean   @default(false)
  lockedAt                    DateTime?
  lockedReason                String?
  customerStatus              String?
  testModeStartedAt           DateTime?
  customerSource              String?
  adminMemo                   String?
  mallNickname                String?
  genieStatus                 String?
  genieLinkedAt               DateTime?
  kakaoChannelAdded           Boolean   @default(false)
  kakaoChannelAddedAt         DateTime?
  createdAt                   DateTime  @default(now())
  updatedAt                   DateTime  @updatedAt
  pwaGenieInstalledAt         DateTime?
  pwaMallInstalledAt          DateTime?
  refundCertificateCount      Int       @default(0)
  grade                       String    @default("regular") @db.VarChar(50)
  isPasswordSet               Boolean   @default(false)
  goldMemberId                Int?
  passwordResetToken          String?
  passwordResetTokenExpiresAt DateTime?
  sourceAgentId               Int?
  affiliateCode               String?   @db.VarChar(4)
  socialEmail                 String?
  socialId                    String?
  socialProvider               String?
  socialProfileImg            String?
  customerGroupId             Int?
  nextActionDate              DateTime?
  nextActionNote              String?

  reservations            GmReservation[]
  travelers               GmTraveler[]
  trips                   GmTrip[]
  passportSubmissions     GmPassportSubmission[]
  passportRequestsSent    GmPassportRequestLog[] @relation("PassportRequestLog_userIdToUser")
  passportRequestsAdmin   GmPassportRequestLog[] @relation("PassportRequestLog_adminIdToUser")

  @@map("User")
}

model GmTrip {
  id              Int       @id @default(autoincrement())
  userId          Int
  productId       Int?
  productCode     String    @default("")
  shipName        String    @default("")
  departureDate   DateTime  @default(now())
  cruiseName      String?
  startDate       DateTime?
  endDate         DateTime?
  nights          Int       @default(0)
  days            Int       @default(0)
  status          String    @default("Upcoming")
  googleFolderId  String?
  spreadsheetId   String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime

  user            GmUser    @relation(fields: [userId], references: [id])
  reservations    GmReservation[]

  @@map("Trip")
}

model GmReservation {
  id                          Int       @id @default(autoincrement())
  tripId                      Int
  mainUserId                  Int
  totalPeople                 Int
  cabinType                   String?
  paymentDate                 DateTime?
  paymentMethod               String?
  paymentAmount               Int?
  agentName                   String?
  remarks                     String?
  passportGroupLink           String?
  passportStatus              String    @default("PENDING")
  affiliateSaleId             Int?
  pnrStatus                   String    @default("PENDING")
  status                      String    @default("CONFIRMED")
  airlineName                 String?
  airlineCode                 String?
  pnrNumber                   String?
  finalConfirmStatus          String    @default("PENDING")
  lastModifiedByName          String?
  groupMemo                   String?
  createdAt                   DateTime  @default(now())
  updatedAt                   DateTime  @default(now()) @updatedAt

  trip                        GmTrip    @relation(fields: [tripId], references: [id], onDelete: Cascade)
  user                        GmUser    @relation(fields: [mainUserId], references: [id])
  travelers                   GmTraveler[]

  @@index([mainUserId])
  @@index([passportStatus])
  @@index([tripId])
  @@index([status])
  @@index([pnrStatus])
  @@index([finalConfirmStatus])
  @@map("Reservation")
}

model GmTraveler {
  id               Int       @id @default(autoincrement())
  reservationId    Int
  roomNumber       Int
  isSingleCharge   Boolean   @default(false)
  engSurname       String?
  engGivenName     String?
  korName          String?
  residentNum      String?
  gender           String?
  birthDate        String?
  passportNo       String?
  issueDate        String?
  expiryDate       String?
  passportImage    String?
  userId           Int?
  nationality      String?
  notes            String?
  phone            String?
  companionGroupId Int?
  roomingGroupId   Int?
  passportDriveUrl String?
  updatedAt        DateTime  @default(now())

  reservation      GmReservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  user             GmUser?       @relation(fields: [userId], references: [id])

  @@index([reservationId])
  @@index([userId])
  @@map("Traveler")
}

model GmAffiliateLead {
  id                    Int       @id @default(autoincrement())
  linkId                Int?
  managerId             Int?
  agentId               Int?
  customerName          String?
  customerPhone         String?
  status                String    @default("NEW")
  source                String?
  passportRequestedAt   DateTime?
  passportCompletedAt   DateTime?
  lastContactedAt       DateTime?
  nextActionAt          DateTime?
  notes                 String?
  metadata              Json?
  leadScore             Int       @default(0)
  leadStage             String    @default("NURTURE")
  groupId               Int?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @default(now()) @updatedAt

  @@index([status])
  @@index([managerId])
  @@index([agentId])
  @@map("AffiliateLead")
}

model GmAffiliateRelation {
  id              Int       @id @default(autoincrement())
  managerId       Int
  agentId         Int
  status          String    @default("ACTIVE")
  connectedAt     DateTime?
  disconnectedAt  DateTime?
  overrideRate    Float?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime

  @@index([managerId])
  @@index([agentId])
  @@map("AffiliateRelation")
}

model GmApisSyncQueue {
  id          Int       @id @default(autoincrement())
  targetType  String
  targetId    Int
  status      String    @default("PENDING")
  attempts    Int       @default(0)
  lastError   String?
  scheduledAt DateTime  @default(now())
  processedAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([status, scheduledAt])
  @@map("ApisSyncQueue")
}

// ─── 여권 관리 (크루즈닷몰 공유) ─────────────────────────

model GmPassportSubmission {
  id             Int       @id @default(autoincrement())
  userId         Int
  tripId         Int?
  token          String
  tokenExpiresAt DateTime
  isSubmitted    Boolean   @default(false)
  submittedAt    DateTime?
  driveFolderUrl String?
  extraData      Json?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @default(now()) @updatedAt

  user           GmUser    @relation(fields: [userId], references: [id])
  guests         GmPassportSubmissionGuest[]

  @@index([userId])
  @@index([token])
  @@map("PassportSubmission")
}

model GmPassportSubmissionGuest {
  id                 Int       @id @default(autoincrement())
  submissionId       Int
  groupNumber        Int
  name               String
  phone              String?
  passportNumber     String?
  nationality        String?
  dateOfBirth        DateTime?
  passportExpiryDate DateTime?
  ocrRawData         Json?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @default(now()) @updatedAt

  submission         GmPassportSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId])
  @@map("PassportSubmissionGuest")
}

model GmPassportRequestLog {
  id             Int      @id @default(autoincrement())
  userId         Int
  adminId        Int
  templateId     Int?
  messageBody    String
  messageChannel String
  status         String
  errorReason    String?
  sentAt         DateTime @default(now())

  user           GmUser   @relation("PassportRequestLog_userIdToUser", fields: [userId], references: [id])
  admin          GmUser   @relation("PassportRequestLog_adminIdToUser", fields: [adminId], references: [id])

  @@index([userId])
  @@index([adminId])
  @@map("PassportRequestLog")
}

model GmPassportRequestTemplate {
  id          Int      @id @default(autoincrement())
  title       String
  body        String
  variables   Json?
  isDefault   Boolean  @default(false)
  updatedById Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  @@map("PassportRequestTemplate")
}

// ─── PNR 감사로그 + 여행계약 ─────────────────────────────

model GmReservationAudit {
  id              Int       @id @default(autoincrement())
  reservationId   Int
  userId          Int?
  action          String
  fieldChanged    String?
  oldValue        String?
  newValue        String?
  reason          String?
  ipAddress       String?
  userAgent       String?
  metadata        Json?
  createdAt       DateTime  @default(now())

  @@index([reservationId, createdAt])
  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@map("ReservationAudit")
}

model GmTravelContract {
  id              Int       @id @default(autoincrement())
  reservationId   Int
  contractUrl     String?
  signedAt        DateTime?
  signedByUserId  Int?
  status          String    @default("PENDING")
  metadata        Json?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @default(now()) @updatedAt

  @@index([reservationId])
  @@index([status])
  @@map("TravelContract")
}

// ─── 웹훅 이벤트 중복 처리 방지 ──────────────────────────
model ProcessedWebhookEvent {
  eventId      String   @id              // GMcruise에서 보내는 UUID v4
  webhookType  String                    // purchase | refund | inquiry | gold-inquiry | partner-signup | news-sync | contract-signed | reservation
  processedAt  DateTime @default(now())

  @@index([webhookType])
  @@map("ProcessedWebhookEvent")
}
