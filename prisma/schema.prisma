// Partner Alert SMS Log (Loop 4)
model PartnerSmsLog {
  id             String  @id @default(cuid())
  organizationId String
  partnerId      String? // Optional for Loop 5 (contactId-based)
  contactId      String? // Loop 5: Contact form submission
  day            String // "day0", "day1", "day2", "day3"
  riskLevel      String? // Loop 4: "RED", "YELLOW", "GREEN" (optional for Loop 5)
  messageType    String // "URGENT_RETENTION", "TRAINING_OFFER", "INCENTIVE", "LOOP5_DAY0_PROBLEM_AGITATE", etc.
  messageContent String  @db.Text
  phoneNumber    String

  // Loop 5: Segment & Variant
  segment String? // "A", "B", "C", "D", "E"
  variant String? // "a", "b" for A/B testing

  // SMS Status
  status        String    @default("PENDING") // "PENDING" | "SENT" | "FAILED" | "BOUNCED" | "CLICKED"
  smsId         String? // Aligo SMS ID
  sentAt        DateTime? @db.Timestamptz(6)
  failureReason String?
  retryCount    Int       @default(0)
  maxRetries    Int       @default(3)

  // Response Tracking
  openedAt  DateTime? @db.Timestamptz(6)
  clickedAt DateTime? @db.Timestamptz(6)

  // Metadata
  triggeredBy String? // "AUTO_RISK_SCORE" | "MANUAL_ADMIN" | "CRON_JOB" | "AUTO_FORM_SUBMISSION"
  metadata    Json?

  partner      Partner?     @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  contact      Contact?     @relation(fields: [contactId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt    DateTime     @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime     @updatedAt @db.Timestamptz(6)

  @@index([organizationId, partnerId])
  @@index([organizationId, contactId])
  @@index([organizationId, status])
  @@index([partnerId, day])
  @@index([contactId, day])
  @@index([segment])
  @@index([riskLevel])
  @@index([sentAt])
  @@map("PartnerSmsLog")
}

// Loop 4: RiskScore 변경 이력 추적
model PartnerRiskScoreChange {
  id             String @id @default(cuid())
