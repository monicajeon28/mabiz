  smsTriggered   Boolean @default(false)
  triggeredSmsId String? // FK to PartnerSmsLog
  smsMessageType String? // "URGENT_RETENTION", "TRAINING_OFFER", "RECOVERY_POSITIVE"

  partner      Partner      @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt    DateTime     @default(now()) @db.Timestamptz(6)

  @@index([organizationId, partnerId])
  @@index([organizationId, currentLevel])
  @@index([currentScore])
  @@index([smsTriggered])
  @@map("PartnerRiskScoreChange")
}

