  groupB_clicked   Int       @default(0)
  groupB_converted Int       @default(0)
  groupB_rate      Float     @default(0)
  // Statistical indicators at this point
  pValue           Float?
  isSignificant    Boolean   @default(false)
  recommendation   String? // Auto-generated insight
  createdAt        DateTime  @default(now())

  @@unique([abTestId, snapshotDate])
  @@index([organizationId, abTestId, dayNumber])
  @@map("SmsABTestTimeline")
}

