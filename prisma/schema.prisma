model GmUserGroup {
  id        Int                 @id @default(autoincrement())
  name      String
  color     String?             @default("#6B7280")
  createdByUserId Int?
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  members   GmUserGroupMember[] @relation("GroupMembers")
  createdBy GmUser?             @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([createdByUserId])
  @@map("GmUserGroup")
}

model GmUserGroupMember {
  id       Int         @id @default(autoincrement())
  groupId  Int
  gmUserId Int
  addedAt  DateTime    @default(now())
  group    GmUserGroup @relation("GroupMembers", fields: [groupId], references: [id], onDelete: Cascade)
  gmUser   GmUser      @relation("UserGroups", fields: [gmUserId], references: [id], onDelete: Cascade)

  @@unique([groupId, gmUserId])
  @@index([gmUserId])
  @@index([groupId])
  @@map("GmUserGroupMember")
}

