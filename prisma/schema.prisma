model CallLog {
  id              String    @id @default(cuid())
  contactId       String
  userId          String
  content         String?
  result          String?
  duration        Int?
  convictionScore Int?
  nextAction      String?
  scheduledAt     DateTime?
  createdAt       DateTime  @default(now())

  // A/B 테스트 메타데이터
  abTestGroup   String? // "A" | "B" | null
  abTestWeek    Int? // 1, 2, 3, ..., 12
  scriptVersion String? // "v13-A-standard" | "v13-B-desire-extended"

  // 콜 단계 추적 (이의처리 Track A와 연동)
  callPhase      String? // "opening" | "desire" | "implication" | "close" | "abandoned"
  phaseStartedAt DateTime? // SPIN 시작 시간

  // 콜 타이밍 (정확한 지속 시간 계산)
  callStartedAt  DateTime? // 콜 수신 시간
  callEndedAt    DateTime? // 콜 종료 시간
  callDurationMs Int? // (callEndedAt - callStartedAt).milliseconds

  // 이탈 분석
  abandonmentMs    Int? // 고객이 끊은 시점 (callStartedAt 기준 밀리초)
  abandonmentPhase String? // 끊긴 단계 ("opening" 중 / "desire" 중 / ...)

  // 녹음 동의 (법적 준수)
  recordingConsent   Boolean   @default(false)
  recordingConsentAt DateTime?

  // A/B 분석 도우미 필드
  conversionDay Int? // 0 (즉시), 1 (다음날), 3 (3일 후), 7 (1주) 등

  // Track A: 이의처리 메타데이터
  objectionId      String? // "A-001" ~ "F-004" (TRACK_A_OBJECTIONS.json 참조)
  customerReaction String? // "positive" | "neutral" | "negative"
  recovered        Boolean? // 이의가 성공적으로 해결되었는가
  recoveryTime     Int? // 이의 해결 시간 (초)

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([contactId])
  @@index([userId])
  @@index([contactId, createdAt(sort: Desc)])
  @@index([abTestGroup])
  @@index([abTestWeek])
  @@index([callStartedAt])
  @@index([abandonmentPhase])
  @@index([objectionId, recovered])
  @@index([customerReaction])
}

