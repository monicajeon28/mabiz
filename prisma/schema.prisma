model SmsABTest {
  id               String              @id @default(cuid())
  organizationId   String
  name             String // e.g., "Day 0 SMS Variants (Week 1)"
  objectiveType    String // "OPEN_RATE", "CLICK_RATE", "CONVERSION", "RESPONSE_TIME"
  psychologyLens   String? // "L6_TIMING", "L1_PRICE", "L10_IMMEDIATE_ACTION"
  copyAngle        String? // "SCARCITY", "URGENCY", "SOCIAL_PROOF"
  variantATemplate String              @db.Text // "Original template"
  variantBTemplate String              @db.Text // "New variant"
  segmentCode      String? // Optional: test only for specific segment
  startedAt        DateTime            @default(now())
  endedAt          DateTime?
  status           String              @default("ACTIVE") // "ACTIVE", "COMPLETED", "PAUSED"
  testDays         Int                 @default(7) // Planned test duration
  minSampleSize    Int                 @default(100) // Min samples per variant before declaring winner
  pValueThreshold  Float               @default(0.05) // Statistical significance threshold
  confidenceLevel  Float               @default(0.95) // 95% confidence interval
  declaredWinner   String? // "A", "B", or null
  declaredAt       DateTime?
  notes            String?             @db.Text
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  // Relations
  results          SmsABTestResult[]   @relation("ABTestResults")
  timelines        SmsABTestTimeline[] @relation("ABTestTimelines")

  @@unique([organizationId, name])
  @@index([organizationId, status])
  @@index([organizationId, endedAt])
  @@index([organizationId, psychologyLens])
  @@map("SmsABTest")
}

model SmsABTestResult {
  id              String    @id @default(cuid())
  abTestId        String
  abTest          SmsABTest @relation("ABTestResults", fields: [abTestId], references: [id], onDelete: Cascade)
  organizationId  String
  abTestGroup     String // "A" or "B"
  // Core metrics
  totalSent       Int       @default(0)
  totalOpened     Int       @default(0)
  totalClicked    Int       @default(0)
  totalConverted  Int       @default(0)
  totalResponded  Int       @default(0)
  // Derived rates
  openRate        Float     @default(0) // 0.0 to 1.0
  clickRate       Float     @default(0)
  conversionRate  Float     @default(0)
  responseRate    Float     @default(0)
  avgResponseTime Int? // in milliseconds
  // Statistics
  chiSquare       Float? // χ² statistic
  zScore          Float? // Z-score
  pValue          Float? // p-value (two-sided)
  ciLower         Float? // 95% CI lower bound
  ciUpper         Float? // 95% CI upper bound
  relativeRisk    Float? // RR (ratio of rates)
  isStatSig       Boolean   @default(false) // p < 0.05
  lastUpdated     DateTime  @updatedAt

  @@unique([abTestId, abTestGroup])
  @@index([organizationId, abTestId])
  @@map("SmsABTestResult")
}

model SmsABTestTimeline {
  id               String    @id @default(cuid())
  abTestId         String
  abTest           SmsABTest @relation("ABTestTimelines", fields: [abTestId], references: [id], onDelete: Cascade)
  organizationId   String
  // Snapshot at specific time
  snapshotDate     DateTime  @default(now())
  dayNumber        Int // 1-7 (or more)
  // Group A metrics
  groupA_sent      Int       @default(0)
  groupA_opened    Int       @default(0)
