  updatedAt                     DateTime  @updatedAt

  contact      Contact      @relation("NextBestActions", fields: [contactId], references: [id], onDelete: Cascade)
  organization Organization @relation("NextBestActions", fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([contactId, organizationId])
  @@index([organizationId, actionType])
  @@index([organizationId, priority])
  @@index([organizationId, status])
  @@index([createdAt])
  @@map("NextBestAction")
}

// Loop 5-C: 폼 최적화 및 A/B 테스트
model FormSubmission {
  id               String   @id @default(cuid())
  variant          String // 'a', 'b', 'c'
  segment          String // 'A', 'B', 'C', 'D', 'E'
  completionTimeMs Int // 폼 작성 소요시간 (ms)
  ageRange         String // '20s', '30s', '40s', '50s', '60s', '70s+'
  preferenceType   String // 'romance', 'family', 'culture' 등
  affiliateCode    String? // 공유 링크 파트너 코드
  userAgent        String // 디바이스 식별
  createdAt        DateTime @default(now())

  @@index([createdAt])
  @@index([variant])
  @@index([segment])
  @@index([variant, createdAt])
  @@map("FormSubmission")
}

// Phase 6: Settlement Webhook Infrastructure
// SettlementLedger: Partner의 월별 정산 기록
model SettlementLedger {
  id                    String    @id @default(cuid())
  partnerId             String
  period                String    @db.VarChar(7) // YYYY-MM format
  settlementId          String    @unique // 크루즈닷몰 정산 ID
  status                String    @default("DRAFT") // DRAFT | APPROVED | LOCKED | PAID
  totalCommission       BigInt    @default(0) // 총 수수료 (센트 단위)
  totalWithholding      BigInt    @default(0) // 총 제외액 (센트 단위)
  netAmount             BigInt    @default(0) // 순 지급액 (센트 단위)
  previousMonthRevenue  BigInt? // 이전달 수입 (Churn 감지용)
  churnDetected         Boolean   @default(false) // 20% 이상 감소 여부
  smsNotificationSentAt DateTime? @db.Timestamptz(6) // SMS 발송 시각
  createdAt             DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt             DateTime  @updatedAt @db.Timestamptz(6)
  partner               Partner   @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@unique([partnerId, period])
  @@index([partnerId, period])
  @@index([status])
  @@index([churnDetected])
}
