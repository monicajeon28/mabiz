  },
  "permissions": {
    "allowlist": {
      "git": ["commit", "push", "pull", "merge"],
      "npm": ["install", "run", "build", "test"],
      "file": ["read", "write", "delete"]
    }
  },
  "notification": {
    "hooks_enabled": true,
    "slack_channel": null,
    "email_enabled": false,
    "summary": "주간 commit/PR/merge/build 통계 및 심리학 적용율"
  }
