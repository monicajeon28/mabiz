{
  "name": "mabiz",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && prisma migrate deploy && next build",
    "build:analyze": "ANALYZE=true next build",
    "start": "next start",
    "lint": "eslint src/ --ext .ts,.tsx",
    "type-check": "tsc --noEmit --skipLibCheck",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run",
    "test:e2e": "cypress run",
    "test:e2e:groups": "cypress run --spec 'cypress/e2e/group-management.cy.ts'",
    "test:e2e:groups:3x": "node scripts/run-e2e-3x.js",
    "test:all": "npm test && npm run test:e2e",
    "script:restore-from-backup": "npx ts-node scripts/restore-from-google-drive.ts && npx ts-node scripts/validate-data-integrity.ts && npx ts-node scripts/insert-restored-data.ts",
    "script:validate-backup": "npx ts-node scripts/validate-data-integrity.ts",
    "script:convert-excel": "npx ts-node scripts/restore-from-google-drive.ts",
    "script:insert-data": "npx ts-node scripts/insert-restored-data.ts",
    "prepare": "node -e \"if(process.env.CI)process.exit(0)\" && husky || true"
  },
