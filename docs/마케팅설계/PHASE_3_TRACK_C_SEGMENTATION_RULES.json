            "description": "조금 고민 중, 검토 단계",
            "conversion_urgency": "보통",
            "sms_frequency": "주 2회",
            "objection_intensity": "중간"
          },
          "pain:3": {
            "level": 3,
            "name": "중간",
            "description": "해야 한다고 느낌, 결정 단계",
            "conversion_urgency": "중상",
            "sms_frequency": "주 3회",
            "objection_intensity": "중상"
          },
          "pain:4": {
            "level": 4,
            "name": "높음",
            "description": "매우 절실, 지금이 아니면 불안함",
            "conversion_urgency": "높음",
            "sms_frequency": "주 4회",
            "objection_intensity": "높음",
            "special_handling": "Track C-D 이의처리 매뉴얼 제공"
          },
          "pain:5": {
            "level": 5,
            "name": "극심",
            "description": "긴급성 극대, 즉시 결정 필요",
            "conversion_urgency": "극도",
            "sms_frequency": "매일",
            "objection_intensity": "극도",
            "special_handling": "인매디엇 클로징 트랙 (L10 전환율 70→95%), 콜 우선순위 최고"
          }
        }
      },
      "call_status_tag": {
        "description": "콜/SMS 진행 상황 (자동 업데이트)",
        "tags": {
          "call:new": {
            "name": "신규 고객",
            "description": "첫 콜 이전",
            "sms_trigger": "콜 스케줄 후 자동 발송"
          },
          "call:completed": {
            "name": "콜 완료",
            "description": "Opening 콜 완료, SMS Day 0-2 준비",
            "sms_trigger": "즉시 Day 0 SMS 발송"
          },
          "call:D0": {
            "name": "Day 0",
            "description": "콜 직후 (0-24h)",
            "sms_content": "핵심 메시지 + 감정적 재연결",
            "sms_trigger": "콜 완료 후 1-4시간 내"
          },
          "call:D1": {
            "name": "Day 1",
            "description": "콜 1일차",
            "sms_content": "가치 증명 + FOMO",
            "sms_trigger": "Day 0 발송 24h 후"
          },
          "call:D3": {
            "name": "Day 3",
            "description": "콜 3일차 (최종)",
            "sms_content": "최후의 기회 + CTA",
            "sms_trigger": "Day 1 발송 48h 후"
          },
          "call:purchased": {
