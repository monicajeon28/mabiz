    "implementation": {
      "pseudocode": `
function assignPlanTag(segment, estimatedBudget) {
  const defaultPlan = { A: 'plan:A', B: 'plan:B', C: 'plan:C', D: 'plan:A' };

  if (!estimatedBudget) return defaultPlan[segment];

  const overrides = {
    '3천만원이하': { A: 'plan:A', B: 'plan:A', C: 'plan:B', D: 'plan:A' },
    '3-5천만원': { A: 'plan:A', B: 'plan:B', C: 'plan:B', D: 'plan:A' },
    '5-7천만원': { A: 'plan:B', B: 'plan:B', C: 'plan:C', D: 'plan:B' },
    '7천만원이상': { A: 'plan:C', B: 'plan:C', C: 'plan:C', D: 'plan:B' }
  };

  return overrides[estimatedBudget][segment] || defaultPlan[segment];
}
      `,
      "always_required": true,
      "cardinality": "1 per contact (exclusive)"
    }
  },
