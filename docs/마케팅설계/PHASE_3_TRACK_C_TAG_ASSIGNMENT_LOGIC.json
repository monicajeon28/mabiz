    "implementation": {
      "pseudocode": `
function assignPainTag(segment, ruleMatched, specialConditions) {
  const basePain = {
    A: 3, B: 4, C: 3, D: 4
  };

  let painLevel = basePain[segment];

  // 특수 조건 보정
  if (specialConditions.healthConcerns && segment === 'D') {
    painLevel = Math.min(painLevel + 1, 5); // max 5
  }

  if (specialConditions.multipleRejections) {
    painLevel = Math.min(painLevel + 1, 5);
  }

  return \`pain:\${painLevel}\`;
}
