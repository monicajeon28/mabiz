          "auto_transition_rule": "최종 상태",
          "sms_template": "welcome_onboarding_{plan}"
        },
        "call:rejected": {
          "description": "거절 확정 (명확한 NO 또는 72h 무반응)",
          "trigger_action": "재활성화 자동 스케줄",
          "next_state": null,
          "auto_transition_rule": "최종 상태 (일시중단 제외)",
          "reactivation_schedule": {
            "L0_day_30": "30일 후",
            "L0_day_60": "60일 후",
            "L0_day_90": "90일 후"
          }
        },
        "call:suspended": {
          "description": "일시 중단 (고객 요청)",
          "trigger_action": "고객 지정 시점 리마인드 (2주 전)",
          "next_state": "call:completed (재개)",
          "auto_transition_rule": "고객 지정 날짜 도달 시 리마인드",
          "resume_date": "고객 지정"
        }
      }
    },
    "state_transition_matrix": {
      "call:new": {
        "trigger": "call_scheduled",
        "action": "keep",
        "note": "콜 스케줄만으로는 상태 변경 X"
      },
      "call:new → call:completed": {
        "trigger": "call_completed_recorded",
        "timestamp": "now",
        "action": "remove call:new, add call:completed",
        "auto_trigger_sms": "day_0_sms_{segment}",
        "delay_sms": "1-4 hours"
      },
      "call:completed → call:D0": {
        "trigger": "day_0_sms_sent",
        "timestamp": "sms_sent_at",
        "action": "remove call:completed, add call:D0",
        "schedule_next": "day_1_sms at (sms_sent_at + 24h)",
        "note": "Day 0 SMS 발송 기록 → 자동 상태 변경"
      },
      "call:D0 → call:D1": {
        "trigger": "day_1_sms_sent",
        "timestamp": "sms_sent_at",
        "action": "remove call:D0, add call:D1",
        "schedule_next": "day_3_sms at (sms_sent_at + 48h)"
      },
      "call:D1 → call:D3": {
        "trigger": "day_3_sms_sent",
        "timestamp": "sms_sent_at",
        "action": "remove call:D1, add call:D3",
        "schedule_next": "check_engagement at (sms_sent_at + 72h)"
      },
      "call:D3 → call:purchased": {
        "trigger": "purchase_completed",
        "timestamp": "purchase_at",
        "action": "remove call:D3, add call:purchased, remove call:rejected (if exists)",
        "auto_trigger_action": "welcome_onboarding_start",
        "note": "최종 성공 상태"
      },
      "call:D3 → call:rejected": {
        "trigger": "72h_timeout_no_engagement OR explicit_rejection",
        "timestamp": "rejection_at OR (72h_after_d3)",
        "action": "remove call:D3, add call:rejected",
        "auto_trigger_action": "schedule_reactivation_l0",
        "note": "최종 실패 상태"
      },
      "call:any → call:suspended": {
        "trigger": "suspension_requested",
        "timestamp": "suspension_at",
        "action": "remove [current_state], add call:suspended",
        "resume_date": "customer_specified",
        "auto_trigger_action": "schedule_resume_reminder at (resume_date - 14days)"
      },
      "call:suspended → call:completed": {
        "trigger": "resume_date_reached",
        "timestamp": "resume_date",
        "action": "remove call:suspended, add call:completed",
        "auto_trigger_action": "send_day_0_sms_again"
      }
    },
    "implementation": {
      "database_trigger": `
CREATE OR REPLACE FUNCTION update_call_status_on_sms()
RETURNS TRIGGER AS $$
BEGIN
  IF NEW.sms_type = 'day_0' AND OLD.sms_status = 'pending' AND NEW.sms_status = 'sent' THEN
    -- call:completed → call:D0
    UPDATE contact_tags SET tag = 'call:D0'
    WHERE contact_id = NEW.contact_id AND tag = 'call:completed';

    -- Schedule Day 1 SMS (24h later)
    INSERT INTO sms_schedule (contact_id, sms_type, scheduled_at)
    VALUES (NEW.contact_id, 'day_1', NOW() + INTERVAL '24 hours');
  END IF;
  RETURN NEW;
END;
$$ LANGUAGE plpgsql;
