  "step_4_call_status_tag_assignment": {
    "description": "고객의 콜/SMS 진행 상황을 추적하는 call:* 태그 자동 부여 및 업데이트",
    "algorithm": {
      "input": "contact_state (new|call_completed|sms_day0_sent|...)",
      "output": "call_status_tag (call:new|call:completed|call:D0|...)",
      "logic": "state_machine with automatic transitions"
    },
    "state_machine": {
      "initial_state": "call:new",
      "states": {
        "call:new": {
          "description": "신규 고객, 콜 전",
          "trigger_action": "스케줄 콜",
