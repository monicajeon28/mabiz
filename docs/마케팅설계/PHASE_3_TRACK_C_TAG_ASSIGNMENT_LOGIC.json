async function markCallCompleted(contactId: string) {
  // 1. Remove call:new tag
  await removeTag(contactId, 'call:new');

  // 2. Add call:completed tag
  await addTag(contactId, 'call:completed');

  // 3. Trigger Day 0 SMS
  await triggerSMSImmediate(contactId, 'day_0');

  // 4. Log in segment_assignment_history
  await logStatusChange(contactId, 'call:completed', 'call_completed_recorded');
}
