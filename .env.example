# ═══════════════════════════════════════════════════════════════════════════════
# Loop 5-B: Environment Variables Template
# 마비즈 CRM 환경변수 설정 가이드 (Loop 5 배포용)
#
# 작성일: 2026-05-28
# 용도: Loop 5 (SMS/Email 자동화, 폼 최적화, 웹훅 인프라)
# 상태: ✅ 완성 (Phase 1-6)
#
# 복사 방법:
# 1. 이 파일 내용을 .env 또는 .env.local 에 복사
# 2. [YOUR_XXX] 값을 실제 값으로 변경
# 3. Vercel 배포시: Settings > Environment Variables 에 추가
# ═══════════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────────
# 1. Database (필수)
# ─────────────────────────────────────────────────────────────────────────────

DATABASE_URL="postgresql://[YOUR_DB_USER]:[YOUR_DB_PASSWORD]@[YOUR_NEON_HOST]-pooler.[REGION].aws.neon.tech/[YOUR_DB_NAME]?sslmode=require&channel_binding=require"
DIRECT_URL="postgresql://[YOUR_DB_USER]:[YOUR_DB_PASSWORD]@[YOUR_NEON_HOST].[REGION].aws.neon.tech/[YOUR_DB_NAME]?sslmode=require"

# ─────────────────────────────────────────────────────────────────────────────
# 2. Aligo SMS API (필수 - Loop 5 SMS 자동화용)
# ─────────────────────────────────────────────────────────────────────────────

# Aligo 계정 정보 (https://aligo.in 가입 후 확인)
ALIGO_API_KEY="[YOUR_ALIGO_API_KEY]"
ALIGO_USER_ID="[YOUR_ALIGO_USER_ID]"
ALIGO_SENDER_PHONE="[YOUR_SENDER_PHONE]"  # 예: 01012345678

# 참고:
# - ALIGO_API_KEY: 알리고 대시보드 > 개인정보 > API KEY
# - ALIGO_USER_ID: 알리고 계정 ID (이메일 기반)
# - ALIGO_SENDER_PHONE: 발신번호 (자동승인된 번호)
# - API Docs: https://aligo.in/api/send/

# ─────────────────────────────────────────────────────────────────────────────
# 3. Nodemailer SMTP (필수 - Loop 5 Email 자동화용)
# ─────────────────────────────────────────────────────────────────────────────

# SMTP 호스트 설정
NODEMAILER_HOST="[YOUR_SMTP_HOST]"              # 예: smtp.gmail.com, smtp.office365.com
NODEMAILER_PORT="587"                           # 일반적으로 587 (TLS) 또는 465 (SSL)
NODEMAILER_USER="[YOUR_SMTP_EMAIL]"             # 예: support@mabiz.co.kr
NODEMAILER_PASS="[YOUR_SMTP_PASSWORD]"          # SMTP 비밀번호 (앱 비밀번호)
NODEMAILER_FROM_NAME="마비즈 CRM"               # 발신자명
NODEMAILER_FROM_EMAIL="support@mabiz.co.kr"     # 발신 이메일

# 이메일 암호화 키 (필수 - Email 비밀번호 암호화용)
EMAIL_ENCRYPT_KEY="[YOUR_ENCRYPT_KEY_32_CHARS]" # 32자 이상 (대소문자+숫자+특수문자 권장)

# Gmail 설정 예시:
# 1. 2단계 인증 활성화
# 2. 앱 비밀번호 생성: https://myaccount.google.com/apppasswords
# 3. NODEMAILER_PASS에 앱 비밀번호 입력
# 4. NODEMAILER_HOST: smtp.gmail.com
# 5. NODEMAILER_PORT: 587

# Office365 설정 예시:
# 1. NODEMAILER_HOST: smtp.office365.com
# 2. NODEMAILER_PORT: 587
# 3. NODEMAILER_USER: your-email@company.com

# ─────────────────────────────────────────────────────────────────────────────
# 4. Vercel Cron 보안 (필수)
# ─────────────────────────────────────────────────────────────────────────────

# Cron 작업 검증 토큰 (Vercel 내부 호출 인증용)
CRON_SECRET="[YOUR_RANDOM_CRON_SECRET]"  # 예: "cron_xxxxxxxxxxxxxxxxxxxx_v2"

# 생성 방법: openssl rand -hex 32
# Vercel 설정: Settings > Environment Variables > Production 에만 추가

# ─────────────────────────────────────────────────────────────────────────────
# 5. Webhook & 보안 (필수)
# ─────────────────────────────────────────────────────────────────────────────

# Webhook 시크릿 (외부 시스템 호출 검증용)
WEBHOOK_SECRET="[YOUR_WEBHOOK_SECRET]"          # 예: "webhook_xxxxxxxxxxxxxxxxxxxx"
WEBHOOK_SECRET_LENGTH="256"                      # 최소 256자 권장

# 폼 제출 웹훅 (Loop 5-C)
MABIZ_INQUIRY_WEBHOOK_SECRET="[YOUR_INQUIRY_SECRET]"  # ⚠️ NEXT_PUBLIC_ 금지 — 클라이언트 번들 노출됨
DEFAULT_ORG_ID="[YOUR_ORG_ID]"  # 서버 전용 — NEXT_PUBLIC_ 금지 (예: "org_001")

# ─────────────────────────────────────────────────────────────────────────────
# 6. Loop 5 Configuration (필수)
# ─────────────────────────────────────────────────────────────────────────────

# SMS Day 0-3 자동화
LOOP5_SMS_ENABLED="true"
LOOP5_SMS_DAY0_DELAY_MS="0"        # Day 0: 즉시
LOOP5_SMS_DAY1_DELAY_MS="86400000" # Day 1: 24시간
LOOP5_SMS_DAY2_DELAY_MS="172800000" # Day 2: 48시간
LOOP5_SMS_DAY3_DELAY_MS="259200000" # Day 3: 72시간

# SMS 야간 차단 설정
LOOP5_SMS_BLOCK_NIGHT="true"
LOOP5_SMS_NIGHT_START="21:00"      # 밤 9시
LOOP5_SMS_NIGHT_END="08:00"        # 아침 8시

# Email Day 0-3 자동화
LOOP5_EMAIL_ENABLED="true"
LOOP5_EMAIL_DAY0_DELAY_MS="0"
LOOP5_EMAIL_DAY1_DELAY_MS="86400000"
LOOP5_EMAIL_DAY2_DELAY_MS="172800000"
LOOP5_EMAIL_DAY3_DELAY_MS="259200000"

# A/B 테스트 Configuration
LOOP5_AB_TEST_ENABLED="true"
LOOP5_AB_TEST_SPLIT_RATIO="0.33,0.33,0.34"  # A:B:C 분배 (합=1.0)

# ─────────────────────────────────────────────────────────────────────────────
# 7. Analytics & Tracking (선택사항)
# ─────────────────────────────────────────────────────────────────────────────

NEXT_PUBLIC_GA_ID="[YOUR_GOOGLE_ANALYTICS_ID]"  # 예: "GA-xxxxx"
NEXT_PUBLIC_SENTRY_DSN="[YOUR_SENTRY_DSN]"      # 에러 추적용

# ─────────────────────────────────────────────────────────────────────────────
# 8. Redis Cache (선택사항)
# ─────────────────────────────────────────────────────────────────────────────

UPSTASH_REDIS_REST_URL="[YOUR_UPSTASH_URL]"
UPSTASH_REDIS_REST_TOKEN="[YOUR_UPSTASH_TOKEN]"

# ─────────────────────────────────────────────────────────────────────────────
# 9. Logging & Monitoring (선택사항)
# ─────────────────────────────────────────────────────────────────────────────

LOG_LEVEL="info"                   # debug, info, warn, error
NODE_ENV="development"             # development, production

# ─────────────────────────────────────────────────────────────────────────────
# 체크리스트: 배포 전 필수 설정
# ─────────────────────────────────────────────────────────────────────────────

# [ ] 1. 데이터베이스 마이그레이션 완료
#        npx prisma migrate deploy
#
# [ ] 2. Aligo SMS API 설정 확인
#        - ALIGO_API_KEY: 알리고 대시보드에서 확인
#        - ALIGO_USER_ID: 가입 계정
#        - ALIGO_SENDER_PHONE: 승인된 발신번호
#
# [ ] 3. Nodemailer SMTP 설정 확인
#        - NODEMAILER_HOST: Gmail/Office365/기타
#        - NODEMAILER_USER: SMTP 계정
#        - NODEMAILER_PASS: 앱 비밀번호
#        - EMAIL_ENCRYPT_KEY: 32자 이상 난수
#
# [ ] 4. Cron Secret 생성 및 설정
#        openssl rand -hex 32 > /tmp/cron_secret.txt
#
# [ ] 5. Webhook Secret 생성 및 설정
#        openssl rand -hex 128 > /tmp/webhook_secret.txt
#
# [ ] 6. .env 파일 .gitignore 에 추가되어 있는지 확인
#        git status | grep ".env"
#
# [ ] 7. 로컬 테스트 실행
#        npm run test:sms
#        npm run test:email
#
# [ ] 8. Vercel 대시보드에 환경변수 추가
#        Settings > Environment Variables
#
# [ ] 9. 빌드 & 배포 테스트
#        npm run build
#
# [ ] 10. 프로덕션 SMS/Email 테스트 (작은 규모로 먼저)

# ─────────────────────────────────────────────────────────────────────────────
# 참고: 보안 주의사항
# ─────────────────────────────────────────────────────────────────────────────

# ⚠️  이 파일은 절대 Git에 커밋하면 안 됨
# ⚠️  비밀번호, API 키는 암호화되어야 함
# ⚠️  Vercel에는 Production 환경변수로만 설정
# ⚠️  로컬 개발: .env.local 또는 .env.development.local 사용
# ⚠️  팀 공유: 1password / AWS Secrets Manager 등 사용
# ⚠️  정기 갱신: API 키는 최소 분기별로 갱신 권장

# ─────────────────────────────────────────────────────────────────────────────
# Google Drive / Calendar
# ─────────────────────────────────────────────────────────────────────────────

GOOGLE_DRIVE_CRM_BACKUP_FOLDER_ID=
GOOGLE_DRIVE_CALL_LOG_FOLDER_ID=
GOOGLE_DRIVE_ROOT_FOLDER_ID=
GOOGLE_DRIVE_CONTRACTS_FOLDER_ID=
GOOGLE_DRIVE_DOCUMENTS_FOLDER_ID=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_CALENDAR_REDIRECT_URI=
GOOGLE_CALENDAR_STATE_SECRET=

# ─────────────────────────────────────────────────────────────────────────────
# PayApp 결제 연동
# ─────────────────────────────────────────────────────────────────────────────

PAYAPP_USERID=
PAYAPP_LINKKEY=
PAYAPP_LINKVAL=
PAYAPP_TRUSTED_PROXY=vercel
PAYAPP_ALLOWED_IPS=

# ─────────────────────────────────────────────────────────────────────────────
# 외부 서비스
# ─────────────────────────────────────────────────────────────────────────────

CRUISEDOT_BASE_URL=https://cruisedot.co.kr
CRUISEDOT_WEBHOOK_SECRET=
ANTHROPIC_API_KEY=
SLACK_WEBHOOK_URL=
MONDAY_API_KEY=
MONDAY_AB_TEST_BOARD_ID=

# ─────────────────────────────────────────────────────────────────────────────
# Cron / Queue
# ─────────────────────────────────────────────────────────────────────────────

QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=
BONSA_ORG_ID=

# ─────────────────────────────────────────────────────────────────────────────
# 앱 설정
# ─────────────────────────────────────────────────────────────────────────────

NEXT_PUBLIC_APP_URL=https://mabizcruisedot.com
PAGINATION_SKIP_MAX=1000
PAGINATION_LIMIT_MAX=100

# ═══════════════════════════════════════════════════════════════════════════════
# 완성: 2026-05-28 | Agent B Loop 5 배포 준비
# 업데이트: 2026-06-05 | Google Drive/Calendar, PayApp, 외부 서비스, Cron/Queue, 앱 설정 추가
# ═══════════════════════════════════════════════════════════════════════════════

# 대리점장 구매확인 발신 URL (미설정 시 https://www.cruisedot.co.kr/api/webhooks/purchase-confirm)
CRUISEDOT_PURCHASE_CONFIRM_URL=

# ─────────────────────────────────────────────────────────────────────────────
# 어필리에이트 발급 후 몰 provision API 호출용 (몰 팀이 발급)
# ─────────────────────────────────────────────────────────────────────────────

# 어필리에이트 발급 후 몰 provision API 호출용 (몰 팀이 발급)
# 크루즈닷몰 어필리에이트 발급 연동 (POST /api/integration/affiliate/upsert)
INTERNAL_PROVISION_URL=https://www.cruisedot.co.kr
INTERNAL_PROVISION_SECRET=your-internal-provision-secret
