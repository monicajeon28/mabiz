# 크루즈닷몰 웹훅 환경변수
# Secret 키 수령 후 .env.local / .env.staging / .env.production에 추가

# ─── 웹훅 시크릿 (POST /api/webhooks/cruisedot-inventory 인증) ───
# Staging (2026-05-24 ~ 2026-05-25)
CRUISEDOT_WEBHOOK_SECRET=sk_staging_xxxxx
CRUISEDOT_INVENTORY_WEBHOOK_SECRET=sk_inv_staging_xxxxx

# Production (2026-05-26+)
CRUISEDOT_WEBHOOK_SECRET=sk_prod_xxxxx
CRUISEDOT_INVENTORY_WEBHOOK_SECRET=sk_inv_prod_xxxxx

# ─── 통합 조회 시크릿 (GET /api/integration/inventory 인증) ───
# 이 값은 크루즈닷몰 팀과 공유 필요 (2026-06-21 통합 테스트 전)
MABIZ_INTEGRATION_SECRET=xxxxx
