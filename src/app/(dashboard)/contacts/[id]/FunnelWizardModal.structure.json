  "props_interface": {
    "FunnelWizardModalProps": {
      "contactId": {
        "type": "string",
        "required": true,
        "description": "연락처 ID (API 저장용)"
      },
      "contactName": {
        "type": "string",
        "required": true,
        "description": "연락처 이름 (헤더 표시용)"
      },
      "open": {
        "type": "boolean",
        "required": true,
        "description": "모달 표시 여부"
      },
      "onClose": {
        "type": "() => void",
        "required": true,
        "description": "닫기 콜백"
      },
      "onSave": {
        "type": "(data: FunnelWizardState & { messages?: Record<0|1|2|3, string> }) => Promise<void>",
        "required": true,
        "description": "저장 콜백 (API 호출용)"
      }
    },

    "StepComponentProps": {
      "state": {
        "type": "FunnelWizardState",
        "description": "전체 마법사 상태"
      },
      "setState": {
        "type": "React.Dispatch<React.SetStateAction<FunnelWizardState>>",
        "description": "상태 업데이트 함수"
      },
      "error": {
        "type": "string",
        "description": "현재 단계의 에러 메시지"
      },
      "setError": {
        "type": "(msg: string) => void",
        "description": "에러 메시지 설정"
      }
    },

    "FunnelWizardState": {
      "step": {
        "type": "1 | 2 | 3 | 4 | 5",
        "description": "현재 단계 (1~5)"
      },
      "selectedLens": {
        "type": "PsychologyLens (L0-L10)",
        "optional": true,
        "description": "선택한 심리 렌즈"
      },
      "selectedStrategy": {
        "type": "string",
        "optional": true,
        "description": "선택한 메시지 전략"
      },
      "customMessages": {
        "type": "Record<0 | 1 | 2 | 3, string>",
        "optional": true,
        "description": "Day 0-3 메시지 내용"
      },
      "schedule": {
        "type": "{ startDate: string; duration: 3 | 7 | 14; hour: 8 | 12 | 18 | ... }",
        "optional": true,
        "description": "발송 스케줄"
      }
    }
  },

  "state_management": {
    "useState_hooks": [
      {
        "name": "state",
        "type": "FunnelWizardState",
        "initial": "{ step: 1 }",
        "updates": "각 단계에서 필드 추가 (selectedLens → selectedStrategy → customMessages → schedule)"
      },
      {
        "name": "error",
        "type": "string",
        "initial": '""',
        "updates": "유효성 검사 실패 시 에러 메시지 설정, 다음 입력 시 초기화"
      },
      {
        "name": "saving",
        "type": "boolean",
        "initial": "false",
        "updates": "onSave 호출 중 true, 완료/오류 시 false"
      }
    ],
    "state_flow": {
      "step_1_to_5": [
        "Step 1: selectedLens 선택",
        "Step 2: selectedStrategy 선택",
        "Step 3: customMessages (Day 0-3) 입력",
        "Step 4: schedule 설정",
        "Step 5: 최종 확인 후 onSave 호출"
      ],
      "validation_sequence": [
        "각 단계 다음 버튼 클릭 시 canProceedToNext() 호출",
        "step별 필수 필드 검증",
        "검증 실패 시 error 설정 및 진행 중단",
        "검증 성공 시 error 초기화 및 다음 단계로 진행"
      ],
      "save_sequence": [
        "Step 5 에서 저장 버튼 클릭",
        "canProceedToNext() 최종 검증",
        "setSaving(true)",
        "await onSave(state)",
        "성공: toast.success + onClose()",
        "실패: error 메시지 표시 + logger.error"
      ]
    }
  },

