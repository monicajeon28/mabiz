  "integration_guide": {
    "usage_example": "ContactSlidePanel.tsx에서 열기",
    "code_snippet": `
import FunnelWizardModal from './FunnelWizardModal';

function ContactSlidePanel() {
  const [wizardOpen, setWizardOpen] = useState(false);

  return (
    <>
      <button onClick={() => setWizardOpen(true)}>
        자동 메시지 마법사 열기
      </button>

      <FunnelWizardModal
        contactId={contact.id}
        contactName={contact.name}
        open={wizardOpen}
        onClose={() => setWizardOpen(false)}
        onSave={async (data) => {
          // API 호출: POST /api/funnel/create-from-wizard
          await fetch('/api/funnel/create-from-wizard', {
            method: 'POST',
            body: JSON.stringify({
              contactId: contact.id,
              lens: data.selectedLens,
              strategy: data.selectedStrategy,
              messages: data.customMessages,
              schedule: data.schedule,
            }),
          });
        }}
      />
    </>
  );
}
    `
  },

  "validation_rules": {
    "step_1": "selectedLens: required (L0-L10 중 하나)",
    "step_2": "selectedStrategy: required (렌즈별 3개 전략 중 하나)",
    "step_3": "customMessages: 최소 1개 이상 메시지 입력 (비어있으면 안됨)",
    "step_4": "schedule.startDate: required + schedule.duration: required (3/7/14) + schedule.hour: required (8~20)",
    "step_5": "최종 저장 전 모든 단계 검증"
  },

