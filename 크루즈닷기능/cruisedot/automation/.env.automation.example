# cruisedot/automation 환경 변수 예제
# 실제 사용 시 이 파일을 복사하여 .env.automation으로 변경하고 값을 채우세요

# ============================================================================
# VERCEL CRON 보안
# ============================================================================
# Vercel Dashboard에서 복사하여 붙여넣기 (Settings → Environment Variables)
CRON_SECRET=your-vercel-cron-secret-key-here

# ============================================================================
# GOOGLE DRIVE API
# ============================================================================
# Google Cloud Console: https://console.cloud.google.com/
# 1. Create new project
# 2. Enable Google Drive API
# 3. Create Service Account
# 4. Download JSON key file

GOOGLE_DRIVE_API_KEY=AIzaSy...your-api-key-here

# Google Drive 폴더 ID (공유 링크에서 추출)
# https://drive.google.com/drive/folders/{FOLDER_ID}
GOOGLE_DRIVE_FOLDER_ID=1a2b3c4d5e6f7g8h9i0j

# 크루즈 정보 사진 폴더 ID (이미지 동기화 대상)
CRUISEINFO_FOLDER_ID=2x3y4z5a6b7c8d9e0f1g

# Affiliate 문서 폴더 ID (배치 정산용)
AFFILIATE_DOCS_FOLDER_ID=3p4q5r6s7t8u9v0w1x2y

# Google Drive Service Account JSON (환경변수로 넘기는 경우)
# Base64 인코딩: cat key.json | base64 | tr -d '\n'
GOOGLE_DRIVE_SERVICE_ACCOUNT_JSON=eyJt...

# ============================================================================
# GOOGLE SHEETS API
# ============================================================================
# Google Cloud Console: 동일 프로젝트에서 Google Sheets API 활성화

GOOGLE_SHEETS_API_KEY=AIzaSy...your-sheets-api-key

# Google Sheets 스프레드시트 ID
# https://docs.google.com/spreadsheets/d/{SPREADSHEET_ID}/edit
GOOGLE_SHEETS_SPREADSHEET_ID=1a2b3c4d5e6f7g8h9i0j1k2l3m4n5o6p

# ============================================================================
# 결제 게이트웨이 - PayApp
# ============================================================================
# PayApp Admin Dashboard: https://admin.payapp.kr/

PAYAPP_WEBHOOK_SECRET=payapp_webhook_secret_key
PAYAPP_API_KEY=payapp_api_key
PAYAPP_API_SECRET=payapp_api_secret

# ============================================================================
# 결제 게이트웨이 - WelcomePayments
# ============================================================================
# WelcomePayments: https://welcomepayments.kr/

WELCOMEPAYMENTS_WEBHOOK_SECRET=welcomepayments_webhook_secret
WELCOMEPAYMENTS_API_KEY=welcomepayments_api_key
WELCOMEPAYMENTS_API_SECRET=welcomepayments_api_secret

# ============================================================================
# 결제 게이트웨이 - 아임포트 (iamport)
# ============================================================================
# 아임포트: https://admin.iamport.kr/

IAMPORT_API_KEY=imp_api_key_123456
IAMPORT_API_SECRET=imp_api_secret_key
IAMPORT_WEBHOOK_SECRET=imp_webhook_secret

# ============================================================================
# 클라우드 스토리지 (이미지 저장소)
# ============================================================================
# 옵션 1: Cloudinary (권장하지 않음 - 메모리 하드코딩만 사용)
# CLOUDINARY_CLOUD_NAME=your-cloud-name
# CLOUDINARY_API_KEY=your-api-key
# CLOUDINARY_API_SECRET=your-api-secret

# 옵션 2: AWS S3
# AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
# AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
# AWS_S3_BUCKET=cruise-guide-images
# AWS_S3_REGION=ap-northeast-2

# ============================================================================
# 데이터베이스
# ============================================================================
# Neon PostgreSQL: https://console.neon.tech/

DATABASE_URL=postgresql://neondb_owner:password@ep-xxx-us-east-1.neon.tech:5432/neondb?sslmode=require

# ============================================================================
# 이메일 서비스
# ============================================================================
# SendGrid: https://sendgrid.com/

SENDGRID_API_KEY=SG.your-api-key-here
SENDGRID_FROM_EMAIL=noreply@cruiseai.co.kr
SENDGRID_FROM_NAME=크루즈닷

# ============================================================================
# Slack 알림 (CRON/WEBHOOK 실패 알림)
# ============================================================================
# Slack Workspace: https://api.slack.com/apps/

SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T00000000/B00000000/XXXXXXXXXXXXXXXXXXXX

# CRON 실패 알림 채널
SLACK_AUTOMATION_ALERTS_CHANNEL=#automation-alerts

# Payment 웹훅 실패 알림
SLACK_PAYMENT_ALERTS_CHANNEL=#payment-alerts

# Image 동기화 완료 알림
SLACK_IMAGE_SYNC_CHANNEL=#image-sync

# ============================================================================
# 로깅 & 모니터링
# ============================================================================
# 로그 레벨: DEBUG | INFO | WARN | ERROR
LOG_LEVEL=INFO

# 에러 트래킹 (Sentry)
SENTRY_DSN=https://your-sentry-key@sentry.io/123456

# ============================================================================
# 이미지 처리 (Sharp)
# ============================================================================
# WebP 품질 (1-100)
SHARP_WEBP_QUALITY=80

# JPEG 품질 (1-100)
SHARP_JPEG_QUALITY=85

# 최대 이미지 크기 (메모리 제한)
SHARP_MAX_IMAGE_SIZE=50MB

# ============================================================================
# CRON 타임아웃
# ============================================================================
# Vercel Pro: 최대 300초 (5분)
# Vercel Free: 최대 10초

CRON_TIMEOUT_SECONDS=300

# ============================================================================
# 성능 튜닝
# ============================================================================
# 배치 청크 크기 (메모리 제약에 따라 조정)
BATCH_CHUNK_SIZE=100

# 동시 처리 수 (예: 이미지 변환)
MAX_CONCURRENT_TASKS=4

# API 재시도 횟수
MAX_RETRIES=3

# API 타임아웃
API_TIMEOUT_MS=30000

# ============================================================================
# 기능 플래그
# ============================================================================
# 이미지 동기화 활성화
ENABLE_IMAGE_SYNC=true

# 결제 웹훅 처리 활성화
ENABLE_PAYMENT_WEBHOOKS=true

# Google Sheets 동기화 활성화
ENABLE_SHEETS_SYNC=true

# 쿠폐 이벤트 발행 활성화
ENABLE_NEWS_AUTOPUBLISH=true

# ============================================================================
# 개발/프로덕션 설정
# ============================================================================
# 환경: development | staging | production
NODE_ENV=production

# API URL
API_URL=https://cruiseai.co.kr

# 이미지 호스팅 URL (CRON에서 생성한 URL)
IMAGE_CDN_URL=https://cruiseai.co.kr/images/webp

# ============================================================================
# 선택 사항: 외부 API 통합
# ============================================================================

# News API (뉴스 자동 발행)
# NEWS_API_KEY=your-news-api-key

# Kakao Map API (지도 통합)
# KAKAO_MAP_API_KEY=your-kakao-map-key

# SendGrid 확장 (이메일 추적)
# SENDGRID_TRACKING_ENABLED=true

# 매일 정산 요약 이메일
DAILY_SETTLEMENT_EMAILS=cfo@cruiseai.co.kr,finance@cruiseai.co.kr
