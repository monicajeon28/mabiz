#!/bin/sh

# ============================================================
# 1단계: API 키 / 시크릿 노출 방지 스캔
# ============================================================
echo "🔍 시크릿 스캔 중..."

# 스테이징된 파일에서 API 키 패턴 검색
STAGED=$(git diff --cached --name-only --diff-filter=ACM)

SECRET_FOUND=0
for FILE in $STAGED; do
  # 바이너리 파일 건너뜀
  if ! git show ":$FILE" 2>/dev/null | grep -qI .; then continue; fi

  # Google API Key (AIza로 시작하는 39자리)
  if git show ":$FILE" | grep -qE 'AIza[0-9A-Za-z_-]{35}'; then
    echo "❌ Google API Key 발견: $FILE"
    SECRET_FOUND=1
  fi

  # Supabase/JWT 시크릿 (service_role 또는 anon key를 코드에 하드코딩)
  if git show ":$FILE" | grep -qE '"eyJ[A-Za-z0-9_-]{50,}'; then
    echo "❌ JWT 하드코딩 발견: $FILE"
    SECRET_FOUND=1
  fi

  # AWS 키
  if git show ":$FILE" | grep -qE 'AKIA[0-9A-Z]{16}'; then
    echo "❌ AWS Access Key 발견: $FILE"
    SECRET_FOUND=1
  fi

  # Neon/PostgreSQL 실제 연결 문자열 (npg_ 패스워드 패턴)
  if git show ":$FILE" | grep -qE 'npg_[A-Za-z0-9]{10,}'; then
    echo "❌ Neon DB 비밀번호 발견: $FILE"
    SECRET_FOUND=1
  fi

  # PostgreSQL 연결 문자열에 실제 비밀번호
  if git show ":$FILE" | grep -qE 'postgresql://[^:]+:[^@\[]{8,}@'; then
    # [YOUR_*] 플레이스홀더는 제외
    if ! git show ":$FILE" | grep -qE 'postgresql://\[YOUR_'; then
      echo "❌ DB 연결 문자열에 실제 비밀번호 발견: $FILE"
      SECRET_FOUND=1
    fi
  fi

  # Supabase PAT (sbp_)
  if git show ":$FILE" | grep -qE 'sbp_[a-f0-9]{40}'; then
    echo "❌ Supabase PAT 발견: $FILE"
    SECRET_FOUND=1
  fi
done

if [ "$SECRET_FOUND" = "1" ]; then
  echo ""
  echo "🚫 커밋 차단: API 키/시크릿이 코드에 포함되어 있습니다."
  echo "   환경변수(.env.local)로 이동 후 다시 커밋하세요."
  exit 1
fi

echo "✅ 시크릿 스캔 통과"

# ============================================================
# 2단계: TypeScript 타입 체크
# ============================================================
echo "🔍 TypeScript 체크 중..."
npx tsc --noEmit --skipLibCheck
if [ $? -ne 0 ]; then
  echo "❌ TypeScript 에러 발견 — 커밋 차단"
  exit 1
fi
echo "✅ TypeScript 통과"

# ============================================================
# 3단계: ESLint (변경 파일만)
# ============================================================
npx lint-staged --no-stash
exit $?
